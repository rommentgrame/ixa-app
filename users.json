function togglePD(){const d=document.getElementById('prof-drop');d.classList.toggle('open');}
function closePD(){const d=document.getElementById('prof-drop');if(d)d.classList.remove('open');}
document.addEventListener('click',e=>{if(!e.target.closest('.upill'))closePD();});

function uploadAvatar(inp){
  if(!inp.files.length)return;
  const f=inp.files[0];
  if(f.size>2*1024*1024){toast('❌ Image trop grande (max 2MB)','err');return;}
  const r=new FileReader();
  r.readAsDataURL(f);
  r.onload=e=>{
    S.user.avatarImg=e.target.result;
    const aidx=S.allUsers.users.findIndex(u=>u.id===S.user.id);
    if(aidx>=0)S.allUsers.users[aidx].avatarImg=S.user.avatarImg;
    saveLocal();updateUserUI();toast('✅ Avatar mis à jour !','ok');
  };
}


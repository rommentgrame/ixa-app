/* ═══ SHORTCUTS ═══ */
function openShortcuts(){document.getElementById('shortcuts-overlay').classList.add('open');}
function closeShortcuts(){document.getElementById('shortcuts-overlay').classList.remove('open');}
function handleShortcut(e){
  if(e.ctrlKey||e.metaKey){
    const k=e.key.toLowerCase();
    if(k==='n'&&!e.shiftKey){e.preventDefault();createChat();closeSB();}
    else if(k==='k'){e.preventDefault();document.getElementById('mi')?.focus();}
    else if(k==='/'&&!e.shiftKey){e.preventDefault();openShortcuts();}
    else if(k===','&&!e.shiftKey){e.preventDefault();openSettings();}
    else if(k==='m'&&!e.shiftKey){e.preventDefault();openMemoryModal();}
    else if(k==='t'&&!e.shiftKey){e.preventDefault();toggleTheme();}
    else if(k==='e'&&!e.shiftKey){e.preventDefault();exportChat();}
    else if(k==='d'&&!e.shiftKey){e.preventDefault();clearChat();}
    else if(k==='o'&&!e.shiftKey){e.preventDefault();document.getElementById('fi')?.click();}
    else if(k==='b'&&!e.shiftKey){e.preventDefault();openSB();}
    else if(k==='s'&&!e.shiftKey){e.preventDefault();syncNow();}
    else if(k==='f'&&!e.shiftKey){e.preventDefault();toggleFocusMode();}
    else if(k==='v'&&e.shiftKey){e.preventDefault();showTab('voice');setMT('voice');}
    else if(k==='l'&&e.shiftKey){e.preventDefault();showTab('learn');setMT('learn');}
    else if(k==='f'&&e.shiftKey){e.preventDefault();showTab('data');setMT('data');}
  }
  if(e.key==='Escape'){
    closeShortcuts();closeSettings();
    const mo=document.getElementById('mo');if(mo&&mo.classList.contains('open'))closeModal();
    document.getElementById('shortcuts-overlay').classList.remove('open');
  }
}


  const av=S.user.avatarImg?`<img src="${S.user.avatarImg}" alt="">`:(S.user.avatar||'👤');
  const avEl=document.getElementById('u-av');
  if(avEl)avEl.innerHTML=S.user.avatarImg?`<img src="${S.user.avatarImg}" style="width:100%;height:100%;object-fit:cover;border-radius:50%">`:av;
  const nm=document.getElementById('u-name');if(nm)nm.textContent=S.user.display_name||S.user.username;
  const rl=document.getElementById('u-role');if(rl)rl.textContent=S.user.role==='admin'?'👑 Admin':'👤 Utilisateur';
  // Profile dropdown
  const pae=document.getElementById('pd-av-emoji');if(pae)pae.textContent=S.user.avatarImg?'':av;
  const pdav=document.getElementById('pd-av-el');
  if(pdav&&S.user.avatarImg)pdav.innerHTML=`<img src="${S.user.avatarImg}" style="width:100%;height:100%;object-fit:cover;border-radius:50%"><div class="pd-av-overlay">📷</div>`;
  const pun=document.getElementById('pd-uname-el');if(pun)pun.textContent=S.user.display_name||S.user.username;
  const prl=document.getElementById('pd-role-el');if(prl)prl.textContent=S.user.role==='admin'?'Administrateur IXA':'Utilisateur';
  const pnc=document.getElementById('pd-nc');if(pnc)pnc.textContent=S.chats.length;
  const pnm=document.getElementById('pd-nm');if(pnm)pnm.textContent=S.memory.length;
  const pnf=document.getElementById('pd-nf');if(pnf)pnf.textContent=Object.keys(S.commands).length;
  if(S.user.role==='admin'){const pa=document.getElementById('pd-admin');if(pa)pa.style.display='';}
}

function updateApiSt(ok=null){
  const el=document.getElementById('ast');if(!el)return;
  if(ok===false){el.className='err';el.innerHTML='⬤ Clé API invalide';return;}
  if(S.groqKey){el.className='ok';el.innerHTML='⬤ IA connectée';}
  else{el.className='err';el.innerHTML='⬤ Clé API manquante';}
  // Update settings modal statuses
  const gs=document.getElementById('s-groq-status');
  if(gs)gs.innerHTML=S.groqKey?`<span style="color:var(--ok)">✅ Configurée</span>`:`<span style="color:var(--err)">❌ Manquante</span>`;
  const ss=document.getElementById('s-serper-status');
  if(ss)ss.innerHTML=S.serperKey?`<span style="color:var(--ok)">✅ Active</span>`:`<span style="color:var(--mu)">— Non configurée</span>`;
}
function updateAst(type){
  const el=document.getElementById('ast');if(!el)return;
  if(type==='sync'){el.className='sync';el.innerHTML='⬤ Synchronisation…';}
  else if(type==='ok'){el.className='ok';el.innerHTML='⬤ IA connectée';}
  else if(type==='err'){el.className='err';el.innerHTML='⬤ Erreur';}
  else if(type==='web'){el.className='web';el.innerHTML='⬤ Recherche web…';}
}

function updateConnBadge(online){
  const b=document.getElementById('conn-badge');if(!b)return;
  if(online){b.className='';b.textContent='● EN LIGNE';}
  else{b.className='off';b.textContent='● HORS LIGNE';}
}
function checkConnection(){updateConnBadge(navigator.onLine);}

/* ═══ CHATS ═══ */
function createChat(){
  const c={id:'c'+Date.now(),title:'Nouvelle conversation',messages:[],pinned:false,tags:[],created:new Date().toISOString()};
  S.chats.unshift(c);S.cid=c.id;
  renderHist();loadChat(c.id);saveLocal();
}
function loadChat(id){
  S.cid=id;
  const msgs=document.getElementById('msgs');msgs.innerHTML='';
  const chat=S.chats.find(c=>c.id===id);
  if(!chat)return;
  if(!chat.messages.length){
    msgs.innerHTML='<div id="welcome"><div class="wlogo">IXA</div><div class="wsub">Système IA de <b>Tom</b> · Posez une question, analysez un fichier ou utilisez un <b>/raccourci</b></div><div id="proactive-slot"></div><div class="wg"><div class="wc" onclick="hint(\'Quelles sont les actualités d\\\'aujourd\\\'hui en France ?\')"><span class="wc-icon">🌐</span><span>Actualités web</span></div><div class="wc" onclick="hint(\'Explique-moi le machine learning avec des exemples concrets\')"><span class="wc-icon">🧠</span><span>Expliquer un concept</span></div><div class="wc" onclick="hint(\'Aide-moi à rédiger un email professionnel\')"><span class="wc-icon">✍️</span><span>Rédiger un message</span></div><div class="wc" onclick="hint(\'Analyse ce code et suggère des améliorations\')"><span class="wc-icon">💻</span><span>Analyser du code</span></div><div class="wc" onclick="hint(\'Génère un rapport PDF complet\')"><span class="wc-icon">📄</span><span>Créer un document</span></div><div class="wc" onclick="hint(\'Fais-moi un tableau Excel de budget\')"><span class="wc-icon">📊</span><span>Créer un tableau</span></div></div></div>';
    loadProactiveCard();
  }else{
    chat.messages.forEach(m=>{
      if(m.role==='user')renderUserMsg(m.displayContent||m.content,[],false,m.ts);
      else renderMsg('assistant',m.content,false,m.ts);
    });
    msgs.scrollTop=msgs.scrollHeight;
  }
  renderHist();
}
function renderHist(filter=''){
  const list=document.getElementById('history-list');
  const chats=filter?S.chats.filter(c=>c.title.toLowerCase().includes(filter.toLowerCase())):S.chats;
  // Sort: pinned first
  const sorted=[...chats.filter(c=>c.pinned),...chats.filter(c=>!c.pinned)];
  list.innerHTML=sorted.map(c=>`
    <div class="ci${c.id===S.cid?' act':''}${c.pinned?' pinned':''}" id="ci_${c.id}" onclick="loadChat('${c.id}');closeSB()">
      <span class="ci-t">${esc(c.title||'Nouvelle conversation')}</span>
      <div class="cia">
        <button class="cib pin" title="${c.pinned?'Désépingler':'Épingler'}" onclick="event.stopPropagation();togglePin('${c.id}')">${c.pinned?'📌':'📍'}</button>
        <button class="cib r" title="Renommer" onclick="event.stopPropagation();renameChat('${c.id}')">✏️</button>
        <button class="cib d" title="Supprimer" onclick="event.stopPropagation();deleteChat('${c.id}')">🗑</button>
      </div>
    </div>`).join('')||'<div style="font-size:.75rem;color:var(--mu);text-align:center;padding:10px">Aucune conversation</div>';
}
function searchChats(v){renderHist(v);}
function togglePin(id){
  const c=S.chats.find(x=>x.id===id);if(!c)return;
  c.pinned=!c.pinned;saveLocal();renderHist();
  toast(c.pinned?'📌 Conversation épinglée':'📌 Conversation désépinglée');
}
function renameChat(id){
  const c=S.chats.find(x=>x.id===id);if(!c)return;
  const ci=document.getElementById('ci_'+id);if(!ci)return;
  const ti=ci.querySelector('.ci-t');
  const old=ti.textContent;
  ti.innerHTML=`<input class="ci-ri" value="${esc(old)}" onclick="event.stopPropagation()" onblur="finishRename('${id}',this.value)" onkeydown="if(event.key==='Enter')this.blur();if(event.key==='Escape'){this.value='${esc(old)}';this.blur();}">`;
  ti.querySelector('input').focus();ti.querySelector('input').select();
}
function finishRename(id,val){
  const c=S.chats.find(x=>x.id===id);if(!c)return;
  if(val.trim())c.title=val.trim().slice(0,60);
  saveLocal();renderHist();
}
function deleteChat(id){
  if(!confirm('Supprimer cette conversation ?'))return;
  S.chats=S.chats.filter(c=>c.id!==id);
  if(S.cid===id){if(S.chats.length){S.cid=S.chats[0].id;loadChat(S.cid);}else createChat();}
  saveLocal();renderHist();toast('🗑 Conversation supprimée');
}
function clearChat(){
  if(!confirm('Effacer tous les messages de cette conversation ?'))return;
  const c=S.chats.find(x=>x.id===S.cid);if(!c)return;
  c.messages=[];saveLocal();loadChat(S.cid);toast('🗑 Chat effacé');
}


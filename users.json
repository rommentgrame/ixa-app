<script>
/* ═══════════════════════════════════════════════════════
   IXA v9 — COMPLETE AI SYSTEM by Tom
   Innovations: 20+ nouvelles fonctionnalités
   Corrections: Vocal, Apprendre, Sync, Design
═══════════════════════════════════════════════════════ */

// ─── GROQ MODELS (Updated 2025 - No decommissioned models) ───
const MODELS = {
  fast:   'llama-3.1-8b-instant',
  smart:  'llama-3.3-70b-versatile',
  doc:    'llama-3.3-70b-versatile',
  vision: 'meta-llama/llama-4-scout-17b-16e-instruct',
  backup: 'gemma2-9b-it',
};
// Vision fallback chain (no decommissioned models)
const CHAINS = {
  vision: ['meta-llama/llama-4-scout-17b-16e-instruct','meta-llama/llama-4-maverick-17b-128e-instruct','llama-3.1-8b-instant','gemma2-9b-it'],
  smart:  ['llama-3.1-8b-instant','llama-3.3-70b-versatile','gemma2-9b-it','mixtral-8x7b-32768'],
  fast:   ['llama-3.1-8b-instant','gemma2-9b-it'],
  doc:    ['llama-3.3-70b-versatile','llama-3.1-8b-instant','gemma2-9b-it'],
};
const TPM = {
  'llama-3.1-8b-instant':6000,'llama-3.3-70b-versatile':12000,
  'llama3-70b-8192':6000,'gemma2-9b-it':15000,'mixtral-8x7b-32768':5000,
  'meta-llama/llama-4-scout-17b-16e-instruct':8000,
  'meta-llama/llama-4-maverick-17b-128e-instruct':8000,
};
const _modelErrors = {};
function markModelError(m){_modelErrors[m]=Date.now()+70000;}
function isModelAvailable(m){return !_modelErrors[m]||Date.now()>_modelErrors[m];}

// ─── SYSTEM PROMPT ───
const SYS = (webContext='') => {
  const u = S.user?.display_name||S.user?.username||'Tom';
  const d = new Date();
  const ds = d.toLocaleDateString('fr-FR',{year:'numeric',month:'long',day:'numeric'});
  const ts = d.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
  const mem = S.memory?.length?'\nMÉMOIRE UTILISATEUR : '+S.memory.join(' | '):'';
  const web = webContext?'\nINFOS WEB EN TEMPS RÉEL :\n'+webContext.slice(0,1600)+'\n':'';
  return `Tu es IXA, l'assistant IA personnel de ${u}. Style inspiré de JARVIS : direct, précis, chaleureux, intelligent.
Réponds TOUJOURS en français sauf demande contraire. Date actuelle : ${ds} à ${ts}.${mem}${web}

GÉNÉRATION DE DOCUMENTS (uniquement si explicitement demandé) :
\`\`\`document:powerpoint
{"title":"TITRE","slides":[{"title":"Diapo 1","content":"Texte introductif","bullets":["Point A","Point B","Point C"]},{"title":"Diapo 2","content":"Contenu","bullets":["Bullet 1","Bullet 2"]}]}
\`\`\`
\`\`\`document:excel
{"sheets":[{"name":"Données","headers":["Col A","Col B","Col C"],"rows":[["val1","val2","val3"]]}]}
\`\`\`
\`\`\`document:pdf
# Titre\n## Section\nContenu Markdown...
\`\`\`
RÈGLE ABSOLUE : JSON/Markdown COMPLET dans les balises. Jamais de JSON brut sans balises.`;
};

// ─── STATE ───
const S = {
  groqKey:'', ghToken:'', ghUser:'', ghRepo:'', ghBranch:'main', serperKey:'',
  user:null, allUsers:null, usersSHA:'',
  chats:[], cid:null, attachments:[], commands:{}, memory:[],
  tab:'chat', loading:false,
  recognition:null, synth:window.speechSynthesis,
  voiceQueue:[], voiceActive:false, voicePaused:false,
  voiceRate:1.0, voicePitch:1.0, voiceIdx:-1, voiceCont:false, voiceRead:true,
  learnDoc:null, learnChatHistory:[], webEnabled:false,
  theme:'dark', autoMemory:false,
  syncInterval:null, lastSync:null,
  modelPref:'auto', focusMode:false,
  draftSaveTimeout:null, draftText:'',
  pinnedChats:[], chatTags:{},
  usageStats:{messages:0,chars:0,docs:0},
  lockPin:'', lockTimeout:15, inactivityTimer:null,
};
window.__docs = {};

function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

/* ═══ BOOT ═══ */
async function boot(){
  setLStat('Chargement de la configuration…');
  // Load localStorage settings first
  const saved={
    groq:  localStorage.getItem('ixa_groq_key'),
    serper:localStorage.getItem('ixa_serper_key'),
    ghTok: localStorage.getItem('ixa_gh_token'),
    ghRepo:localStorage.getItem('ixa_gh_repo'),
    ghBr:  localStorage.getItem('ixa_gh_branch'),
    theme: localStorage.getItem('ixa_theme')||'dark',
    automem:localStorage.getItem('ixa_automem')==='true',
    model: localStorage.getItem('ixa_model_pref')||'auto',
    pin:   localStorage.getItem('ixa_pin')||'',
    lockT: parseInt(localStorage.getItem('ixa_lock_timeout')||'15'),
  };
  S.theme=saved.theme; S.autoMemory=saved.automem; S.modelPref=saved.model;
  S.lockPin=saved.pin; S.lockTimeout=saved.lockT;
  applyTheme();

  // Try config.json
  try{
    const r=await fetch('config.json');
    if(r.ok){
      const cfg=await r.json();
      S.groqKey=(cfg.groq_api_key||'').trim();
      S.ghToken=(cfg.github_token||'').trim();
      S.serperKey=(cfg.serper_key||'').trim();
      const repo=(cfg.github_repo||'').trim();
      if(repo.includes('/')){const p=repo.split('/');S.ghUser=p[0];S.ghRepo=p[1];}
      S.ghBranch=cfg.github_branch||'main';
      if(S.groqKey.startsWith('gsk_'))localStorage.setItem('ixa_groq_key',S.groqKey);
    }
  }catch(e){}

  // Fallback to localStorage
  if(!S.groqKey&&saved.groq?.startsWith('gsk_'))S.groqKey=saved.groq;
  if(!S.serperKey&&saved.serper)S.serperKey=saved.serper;
  if(!S.ghToken&&saved.ghTok)S.ghToken=saved.ghTok;
  if(!S.ghUser&&saved.ghRepo&&saved.ghRepo.includes('/')){const p=saved.ghRepo.split('/');S.ghUser=p[0];S.ghRepo=p[1];}
  if(saved.ghBr)S.ghBranch=saved.ghBr;

  if(S.ghToken&&S.ghUser&&S.ghRepo){
    setLStat('Connexion à la base de données cloud…');
    try{await fetchUsers();}catch(e){S.allUsers=getLocalUsers();}
  }else{S.allUsers=getLocalUsers();}
  setLStat('',true);
  showLoginForm();
}

function getLocalUsers(){
  try{return JSON.parse(localStorage.getItem('ixa_users'))||defaultUsers();}catch(e){return defaultUsers();}
}
function defaultUsers(){
  return{version:'2.0',users:[{
    id:'u001',username:'tom',password:'admin',display_name:'Tom',role:'admin',
    avatar:'👑',avatarImg:null,conversations:[],commands:{},
    memory:['Tom est le créateur et propriétaire du système IXA','IXA est inspiré de JARVIS','Répondre toujours en français'],
    permissions:{canSearch:true,canCreateDocs:true,canManageUsers:true}
  }]};
}
function setLStat(txt,done=false){
  const el=document.getElementById('lstat'),t=document.getElementById('lstat-t');
  if(done){el.style.display='none';return;}
  el.style.display='flex';t.textContent=txt;
}
function showLoginForm(){
  ['li-u','li-p','li-btn'].forEach(id=>document.getElementById(id).style.display='');
  document.getElementById('li-u').focus();
  document.getElementById('li-p').onkeydown=e=>{if(e.key==='Enter')doLogin();};
  document.getElementById('li-u').onkeydown=e=>{if(e.key==='Enter')document.getElementById('li-p').focus();};
}

// ─── BASE64 UTF-8 ───
function b64DecodeUTF8(b64){try{return decodeURIComponent(escape(atob(b64.replace(/\n/g,''))));}catch(e){return atob(b64.replace(/\n/g,''));}}
function b64EncodeUTF8(str){return btoa(unescape(encodeURIComponent(str)));}

/* ═══ GITHUB SYNC ═══ */
async function fetchUsers(){
  const r=await fetch(`https://api.github.com/repos/${S.ghUser}/${S.ghRepo}/contents/users.json`,{
    headers:{'Authorization':`token ${S.ghToken}`,'Accept':'application/vnd.github.v3+json'}
  });
  if(!r.ok)throw new Error('GH '+r.status);
  const d=await r.json();
  S.usersSHA=d.sha;
  S.allUsers=JSON.parse(b64DecodeUTF8(d.content));
  localStorage.setItem('ixa_users',JSON.stringify(S.allUsers));
}

async function pushUsers(){
  if(!S.user||!S.allUsers)return;
  const idx=S.allUsers.users.findIndex(u=>u.id===S.user.id);
  if(idx<0)return;
  S.allUsers.users[idx]={
    ...S.allUsers.users[idx],
    conversations:S.chats.slice(0,50).map(c=>({...c,messages:c.messages.slice(-25)})),
    commands:S.commands,memory:S.memory,
    lastSeen:new Date().toISOString(),
  };
  S.allUsers.updated=new Date().toISOString();
  localStorage.setItem('ixa_users',JSON.stringify(S.allUsers));
  if(!S.ghToken||!S.ghUser||!S.ghRepo)return;
  try{
    // Fetch latest SHA first to avoid conflicts
    try{
      const latest=await fetch(`https://api.github.com/repos/${S.ghUser}/${S.ghRepo}/contents/users.json`,{
        headers:{'Authorization':`token ${S.ghToken}`,'Accept':'application/vnd.github.v3+json'}
      });
      if(latest.ok){const ld=await latest.json();S.usersSHA=ld.sha;}
    }catch(e){}
    const body={message:`IXA sync — ${new Date().toLocaleString('fr-FR')}`,content:b64EncodeUTF8(JSON.stringify(S.allUsers,null,2)),branch:S.ghBranch};
    if(S.usersSHA)body.sha=S.usersSHA;
    const r=await fetch(`https://api.github.com/repos/${S.ghUser}/${S.ghRepo}/contents/users.json`,{
      method:'PUT',headers:{'Authorization':`token ${S.ghToken}`,'Content-Type':'application/json'},
      body:JSON.stringify(body)
    });
    if(r.ok){const d=await r.json();S.usersSHA=d.content?.sha||S.usersSHA;S.lastSync=new Date();updateSyncStatus();}
    else{const e=await r.json();console.error('Push failed',e);}
  }catch(e){console.error('Sync error',e);}
}

async function syncNow(){
  if(!S.ghToken||!S.ghUser||!S.ghRepo){toast('❌ GitHub non configuré — allez dans Paramètres > Sync','err');return;}
  toast('🔄 Synchronisation en cours…');
  updateAst('sync');
  try{
    await pushUsers();
    await fetchUsers();
    // Reload current user data
    const fresh=S.allUsers.users.find(u=>u.id===S.user.id);
    if(fresh){
      S.chats=fresh.conversations||[];S.commands=fresh.commands||{};S.memory=fresh.memory||[];
      renderHist();renderCmds();updateUserUI();
    }
    toast('✅ Synchronisé avec succès !','ok');
    updateAst('ok');
  }catch(e){toast('❌ Erreur de sync: '+e.message,'err');updateAst('err');}
}

async function testGitHub(){
  const tok=(document.getElementById('s-ghtoken')?.value||'').trim()||S.ghToken;
  const repo=(document.getElementById('s-ghrepo')?.value||'').trim()||`${S.ghUser}/${S.ghRepo}`;
  if(!tok||!repo){toast('❌ Configurez le token et le dépôt','err');return;}
  const st=document.getElementById('sync-status');
  if(st)st.textContent='🔄 Test en cours…';
  try{
    const p=repo.split('/');
    const r=await fetch(`https://api.github.com/repos/${p[0]}/${p[1]}`,{
      headers:{'Authorization':`token ${tok}`}
    });
    if(r.ok){
      const d=await r.json();
      if(st)st.innerHTML=`<span style="color:var(--ok)">✅ Connecté à ${esc(d.full_name)} (${d.private?'privé':'public'})</span>`;
    }else{if(st)st.innerHTML=`<span style="color:var(--err)">❌ Erreur ${r.status} — Token ou dépôt invalide</span>`;}
  }catch(e){if(st)st.innerHTML=`<span style="color:var(--err)">❌ Erreur réseau</span>`;}
}

function updateSyncStatus(){
  const el=document.getElementById('sync-status');
  if(el&&S.lastSync)el.innerHTML=`<span style="color:var(--ok)">✅ Dernière sync : ${S.lastSync.toLocaleTimeString('fr-FR')}</span>`;
}

function startSyncInterval(minutes){
  if(S.syncInterval)clearInterval(S.syncInterval);
  if(minutes>0&&S.ghToken&&S.ghUser&&S.ghRepo){
    S.syncInterval=setInterval(()=>pushUsers(),minutes*60000);
  }
}

/* ═══ LOGIN / LOGOUT ═══ */
async function doLogin(){
  const u=(document.getElementById('li-u').value||'').trim().toLowerCase();
  const p=(document.getElementById('li-p').value||'').trim();
  if(!u||!p){document.getElementById('lerr').textContent='Identifiant et mot de passe requis';return;}
  document.getElementById('li-btn').disabled=true;
  if(!S.allUsers){
    setLStat('Connexion…');
    if(S.ghToken&&S.ghUser&&S.ghRepo){try{await fetchUsers();}catch(e){S.allUsers=getLocalUsers();}}
    else{S.allUsers=getLocalUsers();}
    setLStat('',true);
  }
  const user=S.allUsers.users.find(x=>x.username===u&&x.password===p);
  if(!user){document.getElementById('lerr').textContent='Identifiant ou mot de passe incorrect';document.getElementById('li-btn').disabled=false;return;}
  S.user=user;
  S.chats=[...(user.conversations||[])];
  S.commands={...(user.commands||{})};
  S.memory=[...(user.memory||[])];
  saveLocal();
  document.getElementById('login').classList.add('hide');
  setTimeout(()=>document.getElementById('login').style.display='none',450);
  afterLogin();
}

function afterLogin(){
  updateUserUI();
  renderHist();
  renderCmds();
  initSpeech();
  updateApiSt();
  updateUsageStats();
  loadProactiveCard();
  checkConnection();
  // Start sync interval from settings
  const syncInt=parseInt(localStorage.getItem('ixa_sync_int')||'2');
  startSyncInterval(syncInt);
  // Reset inactivity timer
  resetInactivity();
  // Keyboard shortcuts
  document.addEventListener('keydown',handleShortcut);
  // Paste handler
  document.addEventListener('paste',onGlobalPaste);
  // Online/offline detection
  window.addEventListener('online',()=>updateConnBadge(true));
  window.addEventListener('offline',()=>updateConnBadge(false));
  if(!S.chats.length)createChat();
}

function doLogout(){
  if(S.syncInterval)clearInterval(S.syncInterval);
  pushUsers().finally(()=>{
    S.user=null;S.chats=[];S.commands={};S.memory=[];S.cid=null;
    document.getElementById('login').style.display='flex';
    document.getElementById('login').classList.remove('hide');
    document.getElementById('li-u').value='';
    document.getElementById('li-p').value='';
    document.getElementById('li-btn').disabled=false;
    document.getElementById('lerr').textContent='';
    closePD();
    document.removeEventListener('keydown',handleShortcut);
  });
}

function saveLocal(){
  if(!S.user||!S.allUsers)return;
  const idx=S.allUsers.users.findIndex(u=>u.id===S.user.id);
  if(idx>=0){
    S.allUsers.users[idx]={...S.allUsers.users[idx],
      conversations:S.chats.slice(0,60),commands:S.commands,memory:S.memory};
  }
  localStorage.setItem('ixa_users',JSON.stringify(S.allUsers));
}

/* ═══ UI UPDATES ═══ */
function updateUserUI(){

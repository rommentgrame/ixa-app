<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=5.0">
<title>IXA v9 — Système de Tom</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/pptxgenjs@3.12.0/libs/pptxgen.bundle.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Syne:wght@700;800&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════
   IXA v9 — DESIGN SYSTEM
═══════════════════════════════════ */
:root{
  --bg:#07071a;--sb:#0d0d24;--c1:#111130;--c2:#181845;
  --a:#7c6fe0;--a2:#e040fb;--a3:#00e5ff;
  --glow:rgba(124,111,224,.3);--soft:rgba(124,111,224,.12);--softa:rgba(224,64,251,.08);
  --tx:#eaeaf8;--mu:#7070a0;--bd:#1a1a3e;--bd2:#252560;--ub:#141440;
  --err:#ff5252;--ok:#00e676;--warn:#ffab40;--inf:#40c4ff;
  --r:14px;--t:all .22s cubic-bezier(.4,0,.2,1);--sw:268px;--hh:56px;
  --shadow:0 8px 32px rgba(0,0,0,.5);
  --glass:rgba(13,13,36,.85);
  --accent-alt:#ff6584;
}
body.light{
  --bg:#f2f2fc;--sb:#ffffff;--c1:#f7f7ff;--c2:#eeeefc;
  --tx:#1a1a3a;--mu:#7070a0;--bd:#ddddf8;--bd2:#ccccf0;--ub:#e8e8ff;
  --shadow:0 4px 24px rgba(124,111,224,.15);--glass:rgba(255,255,255,.9);
  --soft:rgba(124,111,224,.1);
}
body.light main::before{opacity:.025}
body.light .cb{background:#f0f0ff}

*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden}
body{font-family:'Space Grotesk',sans-serif;background:var(--bg);color:var(--tx);display:flex;transition:background .3s,color .3s}
::-webkit-scrollbar{width:3px;height:3px}
::-webkit-scrollbar-thumb{background:var(--bd2);border-radius:9px}

/* ─── ANIMATIONS ─── */
@keyframes fU{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes fIn{from{opacity:0;transform:scale(.96)}to{opacity:1;transform:scale(1)}}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.85)}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes shimmer{0%{background-position:-400px 0}100%{background-position:400px 0}}
@keyframes slideIn{from{opacity:0;transform:translateX(-12px)}to{opacity:1;transform:translateX(0)}}
@keyframes mI{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes orRing{0%{width:86px;height:86px;top:42px;left:42px;opacity:.9;border-color:var(--a)}100%{width:180px;height:180px;top:0;left:0;opacity:0;border-color:var(--a2)}}
@keyframes glow-pulse{0%,100%{box-shadow:0 0 20px rgba(124,111,224,.3)}50%{box-shadow:0 0 60px rgba(224,64,251,.5)}}

/* ─── LOGIN ─── */
#login{position:fixed;inset:0;background:radial-gradient(ellipse at 35% 40%,#120c2e,#07071a 70%);
  display:flex;align-items:center;justify-content:center;z-index:9000;padding:20px}
#login.hide{animation:fadeOut .4s ease forwards;pointer-events:none}
@keyframes fadeOut{to{opacity:0}}
.lbox{background:var(--sb);border:1px solid var(--bd2);border-radius:22px;padding:38px 32px;
  width:100%;max-width:360px;display:flex;flex-direction:column;gap:16px;
  box-shadow:0 0 100px rgba(124,111,224,.2),0 0 40px rgba(0,0,0,.5);animation:fIn .5s ease}
.lbox::before{content:'';position:absolute;width:200px;height:200px;
  background:radial-gradient(circle,rgba(224,64,251,.1),transparent 70%);
  top:-60px;right:-40px;pointer-events:none}
.llogo{font-family:'Syne',sans-serif;font-size:2.6rem;font-weight:800;text-align:center;
  background:linear-gradient(120deg,var(--a),var(--a2),var(--a3));-webkit-background-clip:text;
  -webkit-text-fill-color:transparent;background-clip:text;letter-spacing:-1px}
.lsub{text-align:center;font-size:.8rem;color:var(--mu);line-height:1.5}
.lsep{height:1px;background:linear-gradient(90deg,transparent,var(--bd2),transparent)}
.lstat{font-size:.74rem;color:var(--mu);display:flex;align-items:center;justify-content:center;gap:7px;min-height:20px}
.spin{width:11px;height:11px;border:2px solid var(--bd2);border-top-color:var(--a);
  border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
.linp{background:var(--c1);border:1px solid var(--bd2);color:var(--tx);padding:12px 14px;
  border-radius:12px;font-size:.88rem;font-family:'Space Grotesk',sans-serif;outline:none;
  transition:.22s;width:100%}
.linp:focus{border-color:var(--a);box-shadow:0 0 0 3px var(--soft)}
.linp::placeholder{color:var(--mu)}
.lbtn{background:linear-gradient(120deg,var(--a),var(--a2));color:#fff;border:none;
  padding:13px;border-radius:12px;font-weight:700;font-size:.9rem;cursor:pointer;
  font-family:'Space Grotesk',sans-serif;transition:var(--t)}
.lbtn:hover{box-shadow:0 8px 28px var(--glow);transform:translateY(-2px)}
.lbtn:disabled{opacity:.45;cursor:not-allowed;transform:none}
.lerr{font-size:.76rem;color:var(--err);text-align:center;min-height:16px}

/* ─── LAYOUT ─── */
#sov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(6px);z-index:199}
#sidebar{width:var(--sw);min-width:var(--sw);background:var(--sb);border-right:1px solid var(--bd);
  display:flex;flex-direction:column;padding:14px 10px;gap:8px;overflow:hidden;
  transition:transform .3s cubic-bezier(.4,0,.2,1);z-index:200;position:relative}
#sidebar::before{content:'';position:absolute;top:-50px;left:-50px;width:180px;height:180px;
  background:radial-gradient(circle,rgba(124,111,224,.08),transparent 70%);pointer-events:none;z-index:0}
main{flex:1;display:flex;flex-direction:column;min-width:0;background:var(--bg);position:relative;overflow:hidden;z-index:1}
main::before{content:'';position:absolute;inset:0;
  background-image:radial-gradient(circle at 1px 1px, var(--bd) 1px, transparent 0);
  background-size:32px 32px;opacity:.08;pointer-events:none;z-index:0}

/* ─── SIDEBAR ─── */
.sbhdr{display:flex;align-items:center;justify-content:space-between;position:relative;z-index:1}
.brand{font-family:'Syne',sans-serif;font-size:1.45rem;font-weight:800;
  background:linear-gradient(120deg,var(--a),var(--a2));-webkit-background-clip:text;
  -webkit-text-fill-color:transparent;background-clip:text;display:flex;align-items:center;gap:7px}
.bdt{width:7px;height:7px;border-radius:50%;background:var(--ok);box-shadow:0 0 10px var(--ok);
  -webkit-text-fill-color:initial;flex-shrink:0;animation:pulse 2.5s infinite}
.xb{background:none;border:none;color:var(--mu);cursor:pointer;padding:5px;border-radius:8px;font-size:.85rem;transition:.2s}
.xb:hover{color:var(--tx);background:var(--c1)}

/* Profile pill */
.upill{background:var(--c1);border:1px solid var(--bd2);border-radius:11px;padding:8px 10px;
  display:flex;align-items:center;gap:8px;cursor:pointer;transition:.2s;position:relative;z-index:1}
.upill:hover{border-color:var(--a);background:var(--c2)}
.uav{width:30px;height:30px;border-radius:50%;background:linear-gradient(120deg,var(--a),var(--a2));
  display:flex;align-items:center;justify-content:center;font-size:.75rem;flex-shrink:0;overflow:hidden}
.uav img{width:100%;height:100%;object-fit:cover;border-radius:50%}
.uname{flex:1;font-weight:600;font-size:.8rem}
.urole{font-size:.64rem;color:var(--mu)}
.logoutb{background:none;border:none;color:var(--mu);cursor:pointer;font-size:.72rem;transition:.2s;padding:4px}
.logoutb:hover{color:var(--err)}

/* Profile dropdown */
.prof-drop{position:absolute;bottom:calc(100% + 6px);left:0;right:0;
  background:var(--sb);border:1px solid var(--bd2);border-radius:14px;
  padding:14px;z-index:300;display:none;flex-direction:column;gap:9px;
  box-shadow:0 -10px 40px rgba(0,0,0,.6);animation:fU .18s ease}
.prof-drop.open{display:flex}
.pd-header{display:flex;align-items:center;gap:10px}
.pd-av{width:46px;height:46px;border-radius:50%;background:linear-gradient(120deg,var(--a),var(--a2));
  display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;
  overflow:hidden;cursor:pointer;transition:.2s;border:2px solid transparent;position:relative}
.pd-av:hover{border-color:var(--a)}
.pd-av img{width:100%;height:100%;object-fit:cover;border-radius:50%}
.pd-av-overlay{position:absolute;inset:0;background:rgba(0,0,0,.5);border-radius:50%;
  display:flex;align-items:center;justify-content:center;opacity:0;transition:.2s;font-size:.75rem}
.pd-av:hover .pd-av-overlay{opacity:1}
.pd-info{flex:1;min-width:0}
.pd-name{font-weight:700;font-size:.9rem}
.pd-role{font-size:.7rem;color:var(--mu)}
.pd-sep{height:1px;background:var(--bd2)}
.pd-item{display:flex;align-items:center;gap:8px;padding:7px 6px;border-radius:8px;
  font-size:.79rem;color:var(--mu);cursor:pointer;transition:.2s}
.pd-item:hover{color:var(--tx);background:var(--c1)}
.pd-item.danger:hover{color:var(--err);background:rgba(255,82,82,.07)}
.pd-stat{display:flex;gap:12px;padding:4px 5px}
.pd-st{display:flex;flex-direction:column;gap:1px;flex:1}
.pd-sv{font-size:.83rem;font-weight:700}
.pd-sk{font-size:.65rem;color:var(--mu)}
#pd-av-inp{display:none}

.btn-new{background:linear-gradient(120deg,var(--a),var(--a2));color:#fff;border:none;
  padding:10px 13px;border-radius:12px;font-weight:600;font-size:.82rem;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:6px;transition:var(--t);
  font-family:'Space Grotesk',sans-serif;width:100%;position:relative;z-index:1}
.btn-new:hover{transform:translateY(-2px);box-shadow:0 8px 24px var(--glow)}

/* Sidebar search */
#hist-search{background:var(--c1);border:1px solid var(--bd2);color:var(--tx);
  padding:7px 10px;border-radius:9px;font-size:.78rem;font-family:'Space Grotesk',sans-serif;
  outline:none;width:100%;transition:.2s;position:relative;z-index:1}
#hist-search:focus{border-color:var(--a)}
#hist-search::placeholder{color:var(--mu)}

.sect{font-size:.6rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  color:var(--mu);padding:1px 4px;margin-top:2px;position:relative;z-index:1}
#history-list{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:2px;position:relative;z-index:1}
.ci{padding:8px 9px;border-radius:9px;font-size:.79rem;color:var(--mu);cursor:pointer;
  transition:var(--t);display:flex;align-items:center;gap:7px;border:1px solid transparent;min-height:34px}
.ci-t{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ci:hover{background:var(--c1);color:var(--tx)}
.ci.act{background:var(--soft);color:var(--a);border-color:rgba(124,111,224,.25)}
.ci.pinned .ci-t::before{content:'📌 ';font-size:.7rem}
.cia{display:flex;gap:1px;opacity:0;flex-shrink:0;transition:.15s}
.ci:hover .cia,.ci.act .cia{opacity:1}
.cib{background:none;border:none;cursor:pointer;padding:3px 5px;border-radius:5px;font-size:.68rem;transition:.15s;color:var(--mu)}
.cib:hover{color:var(--inf)}.cib.d:hover{color:var(--err)}.cib.pin:hover{color:var(--warn)}
.ci-ri{flex:1;background:var(--c1);border:1px solid var(--a);color:var(--tx);
  padding:3px 7px;border-radius:6px;font-size:.77rem;font-family:'Space Grotesk',sans-serif;outline:none}
#ast{font-size:.64rem;display:flex;align-items:center;gap:5px;padding:3px 4px;color:var(--mu)}
#ast.ok{color:var(--ok)}#ast.err{color:var(--err)}#ast.web{color:var(--inf)}
#ast.sync{color:var(--warn);animation:pulse 1s infinite}

/* ─── HEADER ─── */
header{height:var(--hh);padding:0 16px;border-bottom:1px solid var(--bd);
  display:flex;align-items:center;justify-content:space-between;
  background:var(--glass);backdrop-filter:blur(20px);
  position:relative;z-index:10;flex-shrink:0;gap:8px}
.hleft{display:flex;align-items:center;gap:6px;flex-shrink:0}
.mbtn{display:none;background:none;border:none;color:var(--mu);cursor:pointer;padding:7px;border-radius:9px;transition:.2s}
.mbtn:hover{color:var(--a);background:var(--soft)}
.ntabs{display:flex;gap:2px}
.ntab{cursor:pointer;font-weight:500;font-size:.78rem;color:var(--mu);padding:6px 11px;
  border-radius:9px;transition:.22s;border:1px solid transparent;
  display:flex;align-items:center;gap:5px;white-space:nowrap}
.ntab:hover{color:var(--tx);background:var(--c1)}
.ntab.act{color:var(--a);background:var(--soft);border-color:rgba(124,111,224,.3)}
.hright{display:flex;gap:4px;flex-shrink:0;align-items:center}
.hb{background:none;border:1px solid var(--bd2);color:var(--mu);padding:5px 10px;
  border-radius:9px;font-size:.73rem;cursor:pointer;font-family:'Space Grotesk',sans-serif;
  transition:.2s;white-space:nowrap;display:flex;align-items:center;gap:5px}
.hb:hover{border-color:var(--a);color:var(--a)}
.hb.p{border-color:rgba(124,111,224,.35);color:var(--a)}
.hb.p:hover{background:var(--soft)}
.hb.active{background:var(--soft);border-color:var(--a);color:var(--a)}
/* Connection status badge */
#conn-badge{font-size:.62rem;padding:2px 7px;border-radius:5px;font-weight:700;
  background:rgba(0,230,118,.12);color:var(--ok);border:1px solid rgba(0,230,118,.25)}
#conn-badge.off{background:rgba(255,82,82,.1);color:var(--err);border-color:rgba(255,82,82,.2)}

/* ─── MESSAGES ─── */
#msgs{flex:1;overflow-y:auto;padding:20px max(3%,13px);display:flex;flex-direction:column;gap:14px;position:relative;z-index:1;scroll-behavior:smooth}
#welcome{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:14px;text-align:center;padding:20px;animation:fU .5s ease}
.wlogo{font-family:'Syne',sans-serif;font-size:3.2rem;font-weight:800;
  background:linear-gradient(120deg,var(--a),var(--a2),var(--a3));-webkit-background-clip:text;
  -webkit-text-fill-color:transparent;background-clip:text;letter-spacing:-2px;
  animation:glow-pulse 3s infinite}
.wsub{color:var(--mu);font-size:.85rem;max-width:360px;line-height:1.7}
.wsub b{color:var(--a);-webkit-text-fill-color:var(--a)}
.wg{display:grid;grid-template-columns:repeat(2,1fr);gap:7px;margin-top:6px;max-width:420px;width:100%}
.wc{background:var(--c1);border:1px solid var(--bd2);padding:11px 13px;border-radius:12px;
  font-size:.78rem;color:var(--mu);cursor:pointer;transition:.25s;text-align:left;
  display:flex;align-items:flex-start;gap:8px;line-height:1.5}
.wc:hover{border-color:var(--a);color:var(--tx);background:var(--c2);transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.3)}
.wc .wc-icon{font-size:1.1rem;flex-shrink:0;margin-top:1px}
.message{display:flex;gap:9px;align-items:flex-start;animation:mI .22s ease-out;position:relative}
.message.user{flex-direction:row-reverse;align-self:flex-end;max-width:88%}
.message.ass{align-self:flex-start;width:100%;max-width:820px}
.mav{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.76rem;flex-shrink:0;border:2px solid var(--bd2);overflow:hidden}
.message.user .mav{background:linear-gradient(120deg,var(--a),var(--a2));border:none}
.message.ass .mav{background:var(--c2);border-color:rgba(124,111,224,.3)}
.mav img{width:100%;height:100%;object-fit:cover;border-radius:50%}
.mbody{flex:1;min-width:0}
.mrole{font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;margin-bottom:5px;color:var(--mu);display:flex;align-items:center;gap:5px}
.message.user .mrole{justify-content:flex-end;color:var(--a)}
.mtime{font-size:.58rem;color:var(--mu);opacity:.6;font-weight:400;text-transform:none;letter-spacing:0}
.mc{line-height:1.8;font-size:.9rem;color:var(--tx)}
.message.user .mc{background:var(--ub);padding:10px 15px;border-radius:16px 16px 3px 16px;
  border:1px solid var(--bd2);display:inline-block;text-align:left}
.mc h1,.mc h2,.mc h3{margin:14px 0 6px;font-family:'Syne',sans-serif}
.mc h1{font-size:1.3rem}.mc h2{font-size:1.05rem;color:var(--a)}.mc h3{font-size:.9rem;color:var(--mu)}
.mc p{margin-bottom:8px}.mc strong{color:var(--tx);font-weight:600}.mc em{color:var(--mu)}
.mc ul,.mc ol{padding-left:19px;margin-bottom:8px}.mc li{margin-bottom:4px}
.mc a{color:var(--a);text-decoration:none}.mc a:hover{text-decoration:underline}
.mc blockquote{border-left:3px solid var(--a);padding-left:12px;color:var(--mu);margin:9px 0;font-style:italic}
.mc hr{border:none;border-top:1px solid var(--bd2);margin:10px 0}
.mc code:not(pre code){background:var(--c2);border:1px solid var(--bd2);padding:2px 6px;border-radius:5px;font-family:'JetBrains Mono',monospace;font-size:.8em;color:var(--a2)}
.mc table{width:100%;border-collapse:collapse;margin:10px 0;font-size:.82rem}
.mc th,.mc td{border:1px solid var(--bd2);padding:7px 10px;text-align:left}
.mc th{background:var(--c2);color:var(--a);font-weight:600}
.mc tr:nth-child(even) td{background:rgba(124,111,224,.03)}
.cb{background:#03030f;border:1px solid var(--bd2);border-radius:11px;overflow:hidden;margin:9px 0}
.cbh{display:flex;justify-content:space-between;align-items:center;padding:7px 12px;background:var(--c1);border-bottom:1px solid var(--bd2)}
.cbl{color:var(--a);font-family:'JetBrains Mono',monospace;font-size:.68rem;font-weight:500;text-transform:uppercase}
.cpb{background:none;border:1px solid var(--bd2);color:var(--mu);padding:3px 8px;border-radius:5px;font-size:.65rem;cursor:pointer;font-family:'Space Grotesk',sans-serif;transition:.2s}
.cpb:hover{border-color:var(--a);color:var(--a)}.cpb.ok{color:var(--ok);border-color:var(--ok)}
.cb pre{margin:0;padding:13px 15px;font-family:'JetBrains Mono',monospace;font-size:.8rem;overflow-x:auto;line-height:1.65;tab-size:2}
.doc-card{background:linear-gradient(135deg,var(--c2),rgba(124,111,224,.05));border:1px solid rgba(124,111,224,.35);border-radius:13px;padding:14px;margin-top:9px;position:relative;overflow:hidden}
.doc-card::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:linear-gradient(180deg,var(--a),var(--a2))}
.dch{display:flex;align-items:center;gap:8px;margin-bottom:9px;padding-left:9px}
.dci{font-size:1.22rem}.dct{font-weight:600;font-size:.89rem}.dcs{font-size:.7rem;color:var(--mu);margin-top:2px}
.dca{display:flex;gap:5px;flex-wrap:wrap;padding-left:9px}
.dcb{padding:6px 12px;border-radius:9px;font-size:.75rem;cursor:pointer;font-family:'Space Grotesk',sans-serif;transition:.2s;border:none;font-weight:500}
.dcb.dl{background:linear-gradient(120deg,var(--a),var(--a2));color:#fff}
.dcb.dl:hover{transform:translateY(-1px);box-shadow:0 4px 14px var(--glow)}
.dcb.pv{background:var(--c1);border:1px solid var(--bd2);color:var(--mu)}
.dcb.pv:hover{border-color:var(--a);color:var(--a)}
.msg-img{max-height:130px;border-radius:10px;max-width:100%;margin-bottom:6px;display:block;border:1px solid var(--bd2)}
.msg-file{display:inline-flex;align-items:center;gap:6px;background:var(--c2);border:1px solid var(--bd2);padding:5px 10px;border-radius:8px;font-size:.76rem;margin-bottom:6px}
.typing{display:flex;gap:4px;align-items:center;padding:5px 0}
.td{width:6px;height:6px;border-radius:50%;background:var(--a);animation:td 1.2s infinite}
.td:nth-child(2){animation-delay:.22s}.td:nth-child(3){animation-delay:.44s}
@keyframes td{0%,60%,100%{transform:translateY(0);opacity:.3}30%{transform:translateY(-7px);opacity:1}}
.msg-actions{display:flex;gap:3px;margin-top:5px;opacity:0;transition:opacity .18s;flex-wrap:wrap}
.message:hover .msg-actions,.message:focus-within .msg-actions{opacity:1}
.message.user .msg-actions{justify-content:flex-end}
.mact{background:none;border:1px solid var(--bd2);color:var(--mu);padding:3px 8px;border-radius:6px;
  font-size:.68rem;cursor:pointer;font-family:'Space Grotesk',sans-serif;transition:.18s;display:flex;align-items:center;gap:3px}
.mact:hover{border-color:var(--a);color:var(--a);background:var(--soft)}
.mact.ok{border-color:var(--ok);color:var(--ok)}
/* Search indicator */
.search-bar{background:var(--c1);border:1px solid var(--inf);border-radius:10px;padding:9px 13px;
  font-size:.79rem;color:var(--inf);display:flex;align-items:center;gap:8px;margin-bottom:4px}
.search-results{background:var(--c2);border:1px solid var(--bd2);border-radius:10px;padding:10px 13px;font-size:.76rem;margin-bottom:8px}
.search-results .sr-title{font-weight:600;color:var(--tx);margin-bottom:4px;font-size:.8rem}
.search-results .sr-item{color:var(--mu);padding:3px 0;border-bottom:1px solid var(--bd);line-height:1.5}
.search-results .sr-item:last-child{border:none}
.search-results .sr-item a{color:var(--a);font-size:.72rem}

/* ─── INPUT ─── */
#input-area{padding:7px max(3%,11px) 14px;position:relative;z-index:10;flex-shrink:0}
#at{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:5px}
.ach{background:var(--c2);border:1px solid var(--bd2);padding:4px 9px;border-radius:17px;font-size:.72rem;color:var(--a);display:flex;align-items:center;gap:5px}
.arm{cursor:pointer;color:var(--mu);font-size:.84rem;transition:.2s}.arm:hover{color:var(--err)}
#cmd-s{background:var(--c2);border:1px solid var(--bd2);border-radius:11px;padding:4px;margin-bottom:6px;display:none;flex-direction:column;gap:2px;max-height:120px;overflow-y:auto}
.csi{display:flex;align-items:center;gap:8px;padding:7px 9px;border-radius:7px;cursor:pointer;transition:.2s}
.csi:hover{background:var(--soft)}
.csi .cmd{font-family:'JetBrains Mono',monospace;font-size:.73rem;color:var(--a);font-weight:600}
.csi .fn{font-size:.73rem;color:var(--mu)}
.iw{background:var(--c1);border:1px solid var(--bd2);border-radius:16px;padding:6px 9px;
  display:flex;align-items:flex-end;gap:5px;transition:border-color .22s,box-shadow .22s}
.iw:focus-within{border-color:var(--a);box-shadow:0 0 0 3px var(--soft),0 8px 32px rgba(0,0,0,.4)}
textarea{flex:1;background:none;border:none;color:var(--tx);padding:8px 4px;resize:none;outline:none;font-size:.9rem;font-family:'Space Grotesk',sans-serif;line-height:1.6;max-height:150px}
textarea::placeholder{color:var(--mu)}
.abtn{background:none;border:none;color:var(--mu);cursor:pointer;padding:7px;border-radius:8px;transition:.2s;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.abtn:hover{color:var(--a);background:var(--soft)}
.abtn.web-on{color:var(--inf)}
.sbtn{background:linear-gradient(120deg,var(--a),var(--a2));color:#fff;width:34px;height:34px;border-radius:10px;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:var(--t);flex-shrink:0}
.sbtn:hover{transform:scale(1.1);box-shadow:0 4px 18px var(--glow)}
.sbtn:disabled{opacity:.3;transform:none;cursor:not-allowed}
/* Draft saved indicator */
#draft-indicator{font-size:.65rem;color:var(--mu);text-align:right;padding:2px 4px;min-height:16px;transition:.3s}

/* ─── VOICE VIEW ─── */
#voice-view{display:none;flex:1;flex-direction:column;align-items:center;justify-content:center;padding:24px;position:relative;z-index:1;gap:0;overflow-y:auto}
.owrap{position:relative;width:180px;height:180px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.orb{width:88px;height:88px;background:linear-gradient(120deg,var(--a),var(--a2));border-radius:50%;transition:.5s;z-index:2;position:relative;box-shadow:0 0 30px rgba(124,111,224,.3)}
.oring{position:absolute;border-radius:50%;border:1.5px solid;opacity:0}
.listening .oring{animation:orRing 2s infinite}
.listening .oring:nth-child(2){animation-delay:.35s}
.listening .oring:nth-child(3){animation-delay:.7s}
.listening .orb{transform:scale(1.16);box-shadow:0 0 60px var(--glow);animation:glow-pulse 1.5s infinite}
#vst{margin-top:28px;font-weight:300;color:var(--mu);font-size:.96rem;text-align:center;max-width:300px}
#vtr{margin-top:8px;font-size:.83rem;color:var(--tx);max-width:320px;min-height:20px;text-align:center;font-style:italic;line-height:1.5}
#vprog{height:3px;width:220px;background:var(--bd2);border-radius:9px;margin-top:12px;overflow:hidden}
#vpb{height:100%;width:0%;background:linear-gradient(90deg,var(--a),var(--a2),var(--a3));transition:width .4s ease;border-radius:9px}
.vbtn{margin-top:22px;background:linear-gradient(120deg,var(--a),var(--a2));color:#fff;border:none;padding:12px 26px;border-radius:100px;font-weight:600;font-size:.9rem;cursor:pointer;transition:var(--t);font-family:'Space Grotesk',sans-serif;display:flex;align-items:center;gap:8px}
.vbtn:hover{transform:scale(1.05);box-shadow:0 8px 30px var(--glow)}
.voice-settings{margin-top:18px;background:var(--c1);border:1px solid var(--bd2);border-radius:14px;padding:15px 18px;width:100%;max-width:370px;display:flex;flex-direction:column;gap:10px}
.vs-row{display:flex;align-items:center;justify-content:space-between;gap:10px;font-size:.79rem;color:var(--mu)}
.vs-row label{flex-shrink:0;font-weight:500}
.vs-row input[type=range]{flex:1;accent-color:var(--a)}
.vs-row select{background:var(--c2);border:1px solid var(--bd2);color:var(--tx);padding:4px 8px;border-radius:8px;font-size:.77rem;font-family:'Space Grotesk',sans-serif;outline:none;flex:1}
.vcont-toggle{display:flex;align-items:center;gap:7px;font-size:.79rem;color:var(--mu);cursor:pointer}
.vcont-toggle input{accent-color:var(--a)}
/* Voice message list */
.voice-msgs{width:100%;max-width:460px;max-height:220px;overflow-y:auto;display:flex;flex-direction:column;gap:7px;margin-top:10px;padding:3px}
.vms{padding:9px 13px;border-radius:11px;font-size:.82rem;line-height:1.6;animation:fU .3s ease}
.vms.usr{background:var(--ub);border:1px solid var(--bd2);align-self:flex-end;max-width:90%}
.vms.ixa{background:var(--c1);border:1px solid rgba(124,111,224,.2);align-self:flex-start;max-width:95%}
.vms-role{font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--mu);margin-bottom:4px}

/* ─── DATA VIEW ─── */
#data-view{display:none;flex:1;overflow-y:auto;padding:18px max(3%,13px);flex-direction:column;gap:13px;position:relative;z-index:1}
.ds{background:var(--c1);border:1px solid var(--bd2);border-radius:13px;overflow:hidden}
.dsh{padding:12px 15px;border-bottom:1px solid var(--bd2);display:flex;align-items:center;justify-content:space-between;background:var(--c2)}
.dst{font-weight:600;font-size:.86rem;display:flex;align-items:center;gap:7px}
.dsb{padding:13px 15px;display:flex;flex-direction:column;gap:10px}
#fcmd-list{display:flex;flex-direction:column;gap:5px}
.fi2{display:flex;align-items:center;gap:7px;padding:9px 11px;border-radius:10px;background:var(--c2);border:1px solid var(--bd2);font-size:.77rem;cursor:pointer;transition:.2s}
.fi2:hover{border-color:var(--a)}
.fi2-badge{background:var(--soft);color:var(--a);padding:2px 8px;border-radius:5px;font-family:'JetBrains Mono',monospace;font-size:.71rem;font-weight:600;flex-shrink:0}
.fi2-name{flex:1;color:var(--mu);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.fi2-acts{display:flex;gap:2px;opacity:0;flex-shrink:0;transition:.15s}
.fi2:hover .fi2-acts{opacity:1}
.fi2b{background:none;border:none;cursor:pointer;padding:2px 5px;border-radius:4px;font-size:.69rem;transition:.15s;color:var(--mu)}
.fi2b:hover{color:var(--inf)}.fi2b.d:hover{color:var(--err)}
.add-cmd{background:none;border:1px dashed var(--bd2);color:var(--mu);padding:9px;border-radius:10px;font-size:.77rem;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;transition:.2s;font-family:'Space Grotesk',sans-serif;width:100%}
.add-cmd:hover{border-color:var(--a);color:var(--a);background:var(--soft)}
.hint-b{background:var(--c2);border:1px solid var(--bd2);border-radius:10px;padding:11px 13px;font-size:.76rem;color:var(--mu);line-height:1.7}
.hint-b b{color:var(--a)}

/* ─── LEARN VIEW ─── */
#learn-view{display:none;flex:1;overflow-y:auto;padding:18px max(3%,13px) 80px;flex-direction:column;gap:12px;position:relative;z-index:1}
.ldrop{border:2px dashed var(--bd2);border-radius:16px;padding:32px 22px;text-align:center;cursor:pointer;transition:.25s;display:flex;flex-direction:column;align-items:center;gap:10px}
.ldrop:hover,.ldrop.drag{border-color:var(--a);background:var(--soft)}
.ldrop-icon{font-size:2.5rem}
.ldrop-txt{font-size:.83rem;color:var(--mu);line-height:1.7}
.ldoc{background:var(--c1);border:1px solid var(--bd2);border-radius:12px;padding:14px 16px;display:none;flex-direction:column;gap:10px}
.ldoc-name{font-weight:600;font-size:.88rem;display:flex;align-items:center;gap:7px;flex-wrap:wrap}
.ldoc-meta{font-size:.74rem;color:var(--mu);display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.ldoc-meta span{background:var(--c2);border:1px solid var(--bd2);padding:2px 8px;border-radius:5px}
.lacts{display:flex;gap:6px;flex-wrap:wrap}
.lab2{padding:8px 14px;border-radius:10px;font-size:.79rem;cursor:pointer;font-weight:600;font-family:'Space Grotesk',sans-serif;transition:.2s;border:none;display:flex;align-items:center;gap:5px}
.lab2.main{background:linear-gradient(120deg,var(--a),var(--a2));color:#fff}
.lab2.main:hover{transform:translateY(-1px);box-shadow:0 5px 20px var(--glow)}
.lab2.sec{background:var(--c2);border:1px solid var(--bd2);color:var(--mu)}
.lab2.sec:hover{border-color:var(--a);color:var(--a);background:var(--soft)}
.lab2:disabled{opacity:.4;cursor:not-allowed;transform:none !important;box-shadow:none !important}
.laudio-bar{background:var(--c1);border:1px solid var(--bd2);border-radius:12px;padding:14px 16px;display:none;flex-direction:column;gap:9px}
.aprog{height:4px;background:var(--bd2);border-radius:9px;overflow:hidden}
.aprog-b{height:100%;width:0%;background:linear-gradient(90deg,var(--a),var(--a2));transition:width .4s ease;border-radius:9px}
.actrl{display:flex;align-items:center;gap:8px}
.abtn2{background:var(--c2);border:1px solid var(--bd2);color:var(--mu);padding:6px 12px;border-radius:8px;cursor:pointer;font-size:.8rem;transition:.2s}
.abtn2:hover{border-color:var(--a);color:var(--a)}
#a-stat{font-size:.77rem;color:var(--mu)}
/* Learn content - SCROLLABLE */
.lc{display:none;flex-direction:column;gap:10px;overflow-y:auto;max-height:60vh;min-height:0;border-radius:12px}
.lc.active{display:flex}
.expl{background:var(--c1);border:1px solid var(--bd2);border-radius:12px;padding:16px;overflow-y:auto}
/* Learn chat */
.learn-chat-wrap{background:var(--c1);border:1px solid var(--bd2);border-radius:12px;overflow:hidden;display:flex;flex-direction:column}
.learn-chat-msgs{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:10px;min-height:0;max-height:40vh}
.lm{padding:10px 13px;border-radius:10px;font-size:.83rem;line-height:1.65;animation:fU .25s ease}
.lm.user{background:var(--ub);border:1px solid var(--bd2);align-self:flex-end;max-width:85%}
.lm.ai{background:var(--c2);border:1px solid rgba(124,111,224,.2);align-self:flex-start;max-width:95%}
.lm-role{font-size:.6rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--mu);margin-bottom:4px}
.learn-chat-input{display:flex;gap:7px;padding:10px 14px;border-top:1px solid var(--bd2)}
.learn-chat-input input{flex:1;background:var(--bg);border:1px solid var(--bd2);color:var(--tx);padding:8px 12px;border-radius:9px;font-size:.83rem;font-family:'Space Grotesk',sans-serif;outline:none;transition:.2s}
.learn-chat-input input:focus{border-color:var(--a)}
.learn-chat-input button{background:linear-gradient(120deg,var(--a),var(--a2));color:#fff;border:none;padding:8px 14px;border-radius:9px;cursor:pointer;font-size:.83rem;transition:.2s}
.learn-chat-input button:hover{transform:translateY(-1px)}
/* Flashcards */
.fc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px}
.fc{height:130px;cursor:pointer;perspective:600px}
.fc-inner{position:relative;width:100%;height:100%;transform-style:preserve-3d;transition:transform .5s cubic-bezier(.4,0,.2,1)}
.fc.flipped .fc-inner{transform:rotateY(180deg)}
.fc-f,.fc-b{position:absolute;inset:0;backface-visibility:hidden;border-radius:11px;display:flex;align-items:center;justify-content:center;padding:14px;font-size:.82rem;text-align:center;border:1px solid var(--bd2)}
.fc-f{background:var(--c2);color:var(--tx)}
.fc-b{background:linear-gradient(135deg,var(--soft),rgba(224,64,251,.07));color:var(--tx);transform:rotateY(180deg);border-color:rgba(124,111,224,.3)}
/* Quiz */
.quiz-q{background:var(--c1);border:1px solid var(--bd2);border-radius:11px;padding:14px 16px;margin-bottom:10px}
.quiz-qt{font-weight:600;font-size:.86rem;margin-bottom:10px;line-height:1.5}
.quiz-opts{display:flex;flex-direction:column;gap:6px}
.qopt{background:var(--c2);border:1px solid var(--bd2);color:var(--mu);padding:8px 12px;border-radius:8px;cursor:pointer;font-size:.8rem;font-family:'Space Grotesk',sans-serif;text-align:left;transition:.2s}
.qopt:hover{border-color:var(--a);color:var(--a);background:var(--soft)}
.qopt.correct{background:rgba(0,230,118,.1);border-color:var(--ok);color:var(--ok)}
.qopt.wrong{background:rgba(255,82,82,.08);border-color:var(--err);color:var(--err)}
.qopt:disabled{cursor:not-allowed}

/* ─── MOBILE NAV ─── */
#mnav{display:none;height:60px;background:var(--glass);backdrop-filter:blur(20px);border-top:1px solid var(--bd);
  position:fixed;bottom:0;left:0;right:0;z-index:200;align-items:center;justify-content:space-around;padding:0 10px}
.mtab{display:flex;flex-direction:column;align-items:center;gap:3px;font-size:.6rem;color:var(--mu);cursor:pointer;padding:7px 12px;border-radius:11px;transition:.2s;font-weight:500}
.mtab svg{width:21px;height:21px}
.mtab.act{color:var(--a);background:var(--soft)}
.mnew{width:42px;height:42px;background:linear-gradient(120deg,var(--a),var(--a2));border:none;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 18px var(--glow);transition:.2s;flex-shrink:0}
.mnew:hover{transform:scale(1.08)}

/* ─── MODALS ─── */
#mo{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(8px);z-index:500;align-items:center;justify-content:center;padding:16px}
#mo.open{display:flex}
.modal{background:var(--sb);border:1px solid var(--bd2);border-radius:18px;padding:22px;width:100%;max-width:480px;box-shadow:var(--shadow);animation:fIn .2s ease}
.mo-t{font-weight:700;font-size:1.05rem;margin-bottom:14px;font-family:'Syne',sans-serif}
.mo-s{font-size:.83rem;color:var(--mu);line-height:1.65;margin-bottom:12px}
.mbtns{display:flex;gap:8px;justify-content:flex-end;margin-top:14px;flex-wrap:wrap}
.mdb{padding:8px 16px;border-radius:9px;font-size:.8rem;font-weight:600;cursor:pointer;transition:.2s;font-family:'Space Grotesk',sans-serif;border:none}
.mdb.cfm{background:linear-gradient(120deg,var(--a),var(--a2));color:#fff}
.mdb.cfm:hover{box-shadow:0 4px 14px var(--glow);transform:translateY(-1px)}
.mdb.can{background:var(--c1);border:1px solid var(--bd2);color:var(--mu)}
.mdb.can:hover{border-color:var(--a);color:var(--a)}
.mdb.del{background:rgba(255,82,82,.1);border:1px solid rgba(255,82,82,.25);color:var(--err)}
.mdb.del:hover{background:rgba(255,82,82,.2)}
.mi{background:var(--c1);border:1px solid var(--bd2);color:var(--tx);padding:10px 13px;
  border-radius:10px;font-size:.84rem;font-family:'Space Grotesk',sans-serif;outline:none;
  transition:.22s;width:100%}
.mi:focus{border-color:var(--a);box-shadow:0 0 0 3px var(--soft)}
.mi::placeholder{color:var(--mu)}

/* ─── TOAST ─── */
#toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);z-index:9999;display:flex;flex-direction:column;gap:6px;align-items:center;pointer-events:none}
.toast{background:var(--sb);border:1px solid var(--bd2);color:var(--tx);padding:9px 18px;border-radius:100px;font-size:.8rem;box-shadow:0 8px 32px rgba(0,0,0,.4);animation:toastIn .3s ease;pointer-events:none;white-space:nowrap;max-width:90vw;overflow:hidden;text-overflow:ellipsis}
@keyframes toastIn{from{opacity:0;transform:translateY(10px) scale(.95)}to{opacity:1;transform:translateY(0) scale(1)}}
.toast.out{animation:toastOut .3s ease forwards}
@keyframes toastOut{to{opacity:0;transform:translateY(8px) scale(.95)}}

/* ─── SETTINGS MODAL ─── */
#settings-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.78);backdrop-filter:blur(8px);z-index:600;align-items:flex-start;justify-content:center;padding:20px;overflow-y:auto}
#settings-modal.open{display:flex}
.settings-inner{background:var(--sb);border:1px solid var(--bd2);border-radius:20px;padding:0;width:100%;max-width:560px;box-shadow:var(--shadow);animation:fIn .2s ease;overflow:hidden;margin:auto}
.settings-header{padding:20px 24px 16px;border-bottom:1px solid var(--bd2);display:flex;align-items:center;justify-content:space-between;background:var(--c2)}
.settings-title{font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:800;
  background:linear-gradient(120deg,var(--a),var(--a2));-webkit-background-clip:text;
  -webkit-text-fill-color:transparent;background-clip:text}
.settings-tabs{display:flex;gap:2px;padding:14px 24px 0;overflow-x:auto;scrollbar-width:none}
.settings-tabs::-webkit-scrollbar{display:none}
.stab{padding:8px 14px;border-radius:9px 9px 0 0;font-size:.77rem;font-weight:600;
  cursor:pointer;border:none;background:none;color:var(--mu);font-family:'Space Grotesk',sans-serif;
  transition:.2s;white-space:nowrap;border-bottom:2px solid transparent}
.stab.act{color:var(--a);border-bottom-color:var(--a);background:var(--soft)}
.settings-body{padding:20px 24px 24px;max-height:65vh;overflow-y:auto}
.stab-pane{display:none;flex-direction:column;gap:14px;animation:fU .2s ease}
.stab-pane.act{display:flex}
.sfield{display:flex;flex-direction:column;gap:6px}
.sfield label{font-size:.75rem;color:var(--mu);font-weight:600;display:flex;align-items:center;gap:5px}
.sfield .shint{font-size:.7rem;color:var(--mu);line-height:1.5}
.settings-footer{padding:14px 24px;border-top:1px solid var(--bd2);display:flex;justify-content:flex-end;gap:8px}
/* Color picker */
.color-grid{display:flex;gap:8px;flex-wrap:wrap;margin-top:4px}
.color-opt{width:28px;height:28px;border-radius:50%;cursor:pointer;transition:.2s;border:2px solid transparent}
.color-opt:hover,.color-opt.act{border-color:#fff;transform:scale(1.15)}
/* Status indicators */
.api-status-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:6px}
.api-stat-card{background:var(--c1);border:1px solid var(--bd2);border-radius:10px;padding:10px 12px}
.api-stat-label{font-size:.72rem;color:var(--mu);font-weight:600;margin-bottom:5px}
.api-stat-value{font-size:.78rem}

/* ─── SHORTCUTS OVERLAY ─── */
#shortcuts-overlay{position:fixed;inset:0;background:rgba(0,0,0,.82);backdrop-filter:blur(10px);
  z-index:8000;display:none;align-items:center;justify-content:center;padding:20px}
#shortcuts-overlay.open{display:flex}
.sco-box{background:var(--sb);border:1px solid var(--bd2);border-radius:18px;padding:26px;
  max-width:500px;width:100%;max-height:82vh;overflow-y:auto;box-shadow:0 24px 60px rgba(0,0,0,.6)}
.sco-title{font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:800;
  background:linear-gradient(120deg,var(--a),var(--a2));-webkit-background-clip:text;
  -webkit-text-fill-color:transparent;background-clip:text;margin-bottom:16px}
.sco-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.sco-item{display:flex;justify-content:space-between;align-items:center;padding:7px 11px;background:var(--c1);border:1px solid var(--bd2);border-radius:9px;gap:8px}
.sco-desc{font-size:.76rem;color:var(--mu);flex:1}
.sco-key{font-family:'JetBrains Mono',monospace;font-size:.69rem;color:var(--a);background:var(--soft);padding:3px 7px;border-radius:5px;white-space:nowrap;flex-shrink:0}
.sco-section{font-size:.62rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--mu);margin-top:12px;margin-bottom:2px;grid-column:1/-1;padding:0 2px}

/* ─── PROACTIVE CARD ─── */
.proactive-card{background:linear-gradient(135deg,rgba(124,111,224,.1),rgba(224,64,251,.05));
  border:1px solid rgba(124,111,224,.22);border-radius:15px;padding:14px 16px;
  display:flex;flex-direction:column;gap:9px;animation:fU .6s ease}
.pcard-hdr{display:flex;align-items:center;gap:7px;font-size:.77rem;color:var(--a);font-weight:600}
.pcard-msg{font-size:.84rem;color:var(--tx);line-height:1.6}
.pcard-chips{display:flex;gap:5px;flex-wrap:wrap}
.pchip{background:var(--soft);color:var(--a);border:1px solid rgba(124,111,224,.25);
  padding:4px 12px;border-radius:20px;font-size:.72rem;cursor:pointer;transition:.2s;font-weight:500}
.pchip:hover{background:var(--a);color:#fff;transform:scale(1.04)}

/* ─── FOCUS MODE ─── */
body.focus-mode #sidebar{transform:translateX(-100%)}
body.focus-mode .mbtn{display:flex}
body.focus-mode header .ntabs{display:none}

/* ─── RESPONSIVE ─── */
@media(max-width:900px){
  #sidebar{position:fixed;left:0;top:0;bottom:0;transform:translateX(-100%);z-index:200}
  #sidebar.open{transform:translateX(0)}
  #sov.open{display:block}
  .mbtn{display:flex!important}
  header .ntabs{display:none}
  #mnav{display:flex}
  main{padding-bottom:60px}
  .wg{grid-template-columns:1fr 1fr}
  #voice-view{justify-content:flex-start;padding-top:30px}
}
@media(max-width:600px){
  .wg{grid-template-columns:1fr}
  .ntabs{display:none}
  header{padding:0 12px}
  .hright .hb:not(.p):not(#theme-btn){display:none}
  .hb{padding:5px 8px;font-size:.7rem}
  .lacts{gap:4px}
  .lab2{padding:7px 10px;font-size:.74rem}
  .sco-grid{grid-template-columns:1fr}
  .settings-inner{margin:10px 0;border-radius:16px}
  .settings-body{max-height:55vh}
}
@media(min-width:901px) and (max-width:1200px){
  :root{--sw:240px}
}
@media(min-width:1400px){
  :root{--sw:290px}
  .message.ass{max-width:900px}
  #msgs{padding:24px max(5%,24px)}
}
/* Large tablet landscape */
@media(min-width:768px) and (max-width:900px){
  :root{--sw:240px}
  #sidebar{width:var(--sw);position:fixed;left:0;top:0;bottom:0;transform:translateX(-100%)}
}
</style>
</head>
<body>

<!-- ═══ LOGIN ═══ -->
<div id="login">
  <div class="lbox">
    <div class="llogo">IXA</div>
    <div class="lsub">Système IA personnel · Bienvenue, Tom</div>
    <div class="lsep"></div>
    <div class="lstat" id="lstat"><div class="spin"></div><span id="lstat-t">Initialisation…</span></div>
    <input class="linp" id="li-u" placeholder="Identifiant" autocomplete="username" style="display:none">
    <input class="linp" id="li-p" type="password" placeholder="Mot de passe" autocomplete="current-password" style="display:none">
    <div class="lerr" id="lerr"></div>
    <button class="lbtn" id="li-btn" onclick="doLogin()" style="display:none">Connexion</button>
  </div>
</div>

<!-- ═══ APP ═══ -->
<div id="sov" onclick="closeSB()"></div>

<!-- ─ SIDEBAR ─ -->
<div id="sidebar">
  <div class="sbhdr">
    <div class="brand"><span>IXA</span><div class="bdt"></div></div>
    <button class="xb" onclick="closeSB()" title="Fermer">✕</button>
  </div>
  <div class="upill" onclick="togglePD()" id="upill">
    <div class="uav" id="u-av">👤</div>
    <div style="flex:1;min-width:0">
      <div class="uname" id="u-name">—</div>
      <div class="urole" id="u-role">—</div>
    </div>
    <button class="logoutb" onclick="event.stopPropagation();doLogout()" title="Déconnexion">⏻</button>
    <!-- Profile dropdown -->
    <div class="prof-drop" id="prof-drop">
      <div class="pd-header">
        <div class="pd-av" id="pd-av-el" onclick="event.stopPropagation();document.getElementById('pd-av-inp').click()">
          <span id="pd-av-emoji">👤</span>
          <div class="pd-av-overlay">📷</div>
        </div>
        <div class="pd-info">
          <div class="pd-name" id="pd-uname-el">—</div>
          <div class="pd-role" id="pd-role-el">—</div>
        </div>
      </div>
      <input type="file" id="pd-av-inp" accept="image/*" onchange="uploadAvatar(this)">
      <div class="pd-sep"></div>
      <div class="pd-stat">
        <div class="pd-st"><div class="pd-sv" id="pd-nc">0</div><div class="pd-sk">Conversations</div></div>
        <div class="pd-st"><div class="pd-sv" id="pd-nm">0</div><div class="pd-sk">Mémoires</div></div>
        <div class="pd-st"><div class="pd-sv" id="pd-nf">0</div><div class="pd-sk">Raccourcis</div></div>
      </div>
      <div class="pd-sep"></div>
      <div class="pd-item" onclick="closePD();openSettings('account')">👤 Modifier le profil</div>
      <div class="pd-item" onclick="closePD();openMemoryModal()">🧠 Gérer la mémoire</div>
      <div class="pd-item" onclick="closePD();openSettings('sync')">🔄 Synchronisation</div>
      <div id="pd-admin" style="display:none"><div class="pd-item" onclick="closePD();openUserMgmt()">👥 Gestion utilisateurs</div></div>
      <div class="pd-sep"></div>
      <div class="pd-item danger" onclick="doLogout()">⏻ Se déconnecter</div>
    </div>
  </div>
  <button class="btn-new" onclick="createChat();closeSB()">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Nouvelle conversation
  </button>
  <input id="hist-search" placeholder="🔍 Rechercher dans les chats…" oninput="searchChats(this.value)">
  <div class="sect">Conversations</div>
  <div id="history-list"></div>
  <div id="ast">⬤ Prêt</div>
</div>

<!-- ─ MAIN ─ -->
<main>
  <header>
    <div class="hleft">
      <button class="mbtn" onclick="openSB()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="ntabs">
        <span id="tab-chat" class="ntab act" onclick="showTab('chat')">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Chat
        </span>
        <span id="tab-voice" class="ntab" onclick="showTab('voice')">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/></svg>Vocal
        </span>
        <span id="tab-data" class="ntab" onclick="showTab('data')">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>Fichiers
        </span>
        <span id="tab-learn" class="ntab" onclick="showTab('learn')">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>Apprendre
        </span>
      </div>
    </div>
    <div class="hright">
      <span id="conn-badge">● EN LIGNE</span>
      <button class="hb" id="theme-btn" onclick="toggleTheme()" title="Changer le thème">🌙</button>
      <button class="hb p" onclick="openSettings()" title="Paramètres (Ctrl+,)">⚙️</button>
      <button class="hb" onclick="openShortcuts()" title="Raccourcis (Ctrl+/)">⌨️</button>
      <button class="hb" onclick="clearChat()" title="Effacer">🗑</button>
      <button class="hb p" onclick="exportChat()" title="Exporter">📤</button>
    </div>
  </header>

  <!-- CHAT VIEW -->
  <div id="chat-view" style="display:flex;flex:1;flex-direction:column;overflow:hidden">
    <div id="msgs">
      <div id="welcome">
        <div class="wlogo">IXA</div>
        <div class="wsub">Système IA de <b>Tom</b> · Posez une question, analysez un fichier ou utilisez un <b>/raccourci</b></div>
        <div id="proactive-slot"></div>
        <div class="wg">
          <div class="wc" onclick="hint('Quelles sont les actualités d\'aujourd\'hui en France ?')"><span class="wc-icon">🌐</span><span>Actualités web</span></div>
          <div class="wc" onclick="hint('Explique-moi le machine learning avec des exemples concrets')"><span class="wc-icon">🧠</span><span>Expliquer un concept</span></div>
          <div class="wc" onclick="hint('Aide-moi à rédiger un email professionnel')"><span class="wc-icon">✍️</span><span>Rédiger un message</span></div>
          <div class="wc" onclick="hint('Analyse ce code et suggère des améliorations')"><span class="wc-icon">💻</span><span>Analyser du code</span></div>
          <div class="wc" onclick="hint('Génère un rapport PDF sur la productivité')"><span class="wc-icon">📄</span><span>Créer un document</span></div>
          <div class="wc" onclick="hint('Fais-moi un tableau Excel de budget mensuel')"><span class="wc-icon">📊</span><span>Créer un tableau</span></div>
        </div>
      </div>
    </div>
    <div id="input-area">
      <div id="at"></div>
      <div id="cmd-s"></div>
      <div class="iw">
        <input type="file" id="fi" hidden multiple
          accept=".txt,.md,.csv,.json,.js,.ts,.py,.html,.css,.xml,.yaml,.yml,.pdf,.png,.jpg,.jpeg,.gif,.webp,.xlsx,.xls,.docx,.doc,.pptx"
          onchange="handleFiles(this)">
        <button class="abtn" title="Joindre (Ctrl+O)" onclick="document.getElementById('fi').click()">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
        </button>
        <button class="abtn" id="web-btn" title="Recherche web" onclick="toggleWebSearch()">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </button>
        <button class="abtn" id="focus-btn" title="Mode focus" onclick="toggleFocusMode()">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
        </button>
        <textarea id="mi" placeholder="Écrivez ou déposez un fichier… /raccourci pour vos fichiers" rows="1" oninput="onInput(this)" onkeydown="onKey(event)" onpaste="onPaste(event)"></textarea>
        <button class="sbtn" id="sbtn" onclick="handleSend()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </div>
      <div id="draft-indicator"></div>
    </div>
  </div>

  <!-- VOICE VIEW -->
  <div id="voice-view">
    <div class="owrap" id="orb-box">
      <div class="oring"></div><div class="oring"></div><div class="oring"></div>
      <div class="orb">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.7)" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/></svg>
      </div>
    </div>
    <div id="vst">En attente de vos instructions, Tom</div>
    <div id="vtr"></div>
    <div id="vprog"><div id="vpb"></div></div>
    <button class="vbtn" id="vbtn" onclick="toggleVoice()">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
      Activer IXA
    </button>
    <div class="voice-settings">
      <div class="vs-row">
        <label>🎙️ Voix :</label>
        <select id="v-voice-sel" onchange="updateVoiceSetting()"></select>
      </div>
      <div class="vs-row">
        <label>⚡ Vitesse : <span id="v-rate-val">1.0×</span></label>
        <input type="range" id="v-rate" min="0.6" max="2.0" step="0.1" value="1.0" oninput="updateVoiceRate(this.value)">
      </div>
      <div class="vs-row">
        <label>🎵 Tonalité : <span id="v-pitch-val">1.0</span></label>
        <input type="range" id="v-pitch" min="0.5" max="1.6" step="0.1" value="1.0" oninput="updateVoicePitch(this.value)">
      </div>
      <label class="vcont-toggle">
        <input type="checkbox" id="v-cont" onchange="S.voiceCont=this.checked">
        🔄 Mode continu (écoute automatique après réponse)
      </label>
      <label class="vcont-toggle">
        <input type="checkbox" id="v-show-msgs" checked>
        💬 Afficher les messages dans la vue vocale
      </label>
    </div>
    <div class="voice-msgs" id="voice-msgs"></div>
  </div>

  <!-- DATA VIEW -->
  <div id="data-view">
    <div class="ds">
      <div class="dsh">
        <div class="dst">⚡ Raccourcis Fichiers</div>
        <button class="hb p" onclick="openAddCmd()">＋ Ajouter</button>
      </div>
      <div class="dsb">
        <div id="fcmd-list"></div>
        <div class="hint-b">
          Tapez <b>/raccourci votre question</b> dans le chat pour analyser le fichier associé.<br>
          Exemple : <b>/planning qu'ai-je demain ?</b>
        </div>
        <button class="add-cmd" onclick="openAddCmd()">＋ Ajouter un raccourci</button>
      </div>
    </div>
    <!-- Stats card -->
    <div class="ds">
      <div class="dsh"><div class="dst">📊 Statistiques d'usage</div></div>
      <div class="dsb">
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px" id="usage-stats"></div>
      </div>
    </div>
    <!-- Quick actions -->
    <div class="ds">
      <div class="dsh"><div class="dst">🚀 Actions rapides</div></div>
      <div class="dsb">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:7px">
          <button class="mdb can" onclick="exportChat()" style="justify-content:center">📤 Exporter chat</button>
          <button class="mdb can" onclick="exportFullBackup()" style="justify-content:center">📦 Backup complet</button>
          <button class="mdb can" onclick="openMemoryModal()" style="justify-content:center">🧠 Gérer mémoire</button>
          <button class="mdb can" onclick="syncNow()" style="justify-content:center">🔄 Synchroniser</button>
        </div>
      </div>
    </div>
  </div>

  <!-- LEARN VIEW -->
  <div id="learn-view">
    <div class="ds">
      <div class="dsh">
        <div class="dst">📚 Mode Apprentissage Intelligent</div>
        <button class="hb" onclick="learnReset()" id="learn-reset-btn" style="display:none">✕ Reset</button>
      </div>
      <div class="dsb">
        <input type="file" id="lf" hidden accept=".txt,.md,.csv,.json,.pdf,.png,.jpg,.jpeg,.xlsx,.docx,.pptx,.html,.py,.js" onchange="learnLoad(this)">
        <div class="ldrop" id="ldrop"
          onclick="document.getElementById('lf').click()"
          ondragover="event.preventDefault();this.classList.add('drag')"
          ondrop="lDrop(event)" ondragleave="this.classList.remove('drag')">
          <div class="ldrop-icon">📂</div>
          <div class="ldrop-txt">Cliquez ou déposez votre document ici<br><span style="font-size:.72rem;opacity:.7">PDF • Image • Texte • Excel • Word • PowerPoint • Code…</span></div>
        </div>
        <div class="ldoc" id="ldoc">
          <div class="ldoc-name" id="ldoc-nm"></div>
          <div class="ldoc-meta" id="ldoc-mt"></div>
          <div class="lacts" id="learn-actions">
            <button class="lab2 main" id="lb-sum" onclick="learnGen('summary')">📋 Résumé</button>
            <button class="lab2 sec" id="lb-audio" onclick="learnGen('audio')">🎧 Écouter</button>
            <button class="lab2 sec" id="lb-fc" onclick="learnGen('flash')">🃏 Flashcards</button>
            <button class="lab2 sec" id="lb-quiz" onclick="learnGen('quiz')">🧩 Quiz</button>
            <button class="lab2 sec" id="lb-chat" onclick="learnGen('chat')">💬 Chat avec le doc</button>
            <button class="lab2 sec" id="lb-mind" onclick="learnGen('mindmap')">🗺️ Carte mentale</button>
            <button class="lab2 sec" id="lb-tl" onclick="learnGen('timeline')">📅 Chronologie</button>
            <button class="lab2 sec" id="lb-key" onclick="learnGen('keywords')">🔑 Mots-clés</button>
          </div>
        </div>
        <div class="laudio-bar" id="laudio">
          <div style="font-size:.8rem;font-weight:600;display:flex;align-items:center;gap:6px">🎧 <span id="laudio-title">Lecture audio…</span></div>
          <div class="aprog"><div class="aprog-b" id="apb"></div></div>
          <div class="actrl">
            <button class="abtn2" id="a-pp" onclick="audioToggle()">⏸</button>
            <button class="abtn2" onclick="audioStop()">⏹</button>
            <span id="a-stat">Lecture…</span>
          </div>
        </div>
        <div class="lc" id="lc"></div>
      </div>
    </div>
  </div>
</main>

<!-- ─ MOBILE NAV ─ -->
<nav id="mnav">
  <div class="mtab act" id="mn-chat" onclick="showTab('chat');setMT('chat')">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>Chat
  </div>
  <button class="mnew" onclick="createChat();closeSB()">
    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
  </button>
  <div class="mtab" id="mn-voice" onclick="showTab('voice');setMT('voice')">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/></svg>Vocal
  </div>
  <div class="mtab" id="mn-learn" onclick="showTab('learn');setMT('learn')">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>Apprendre
  </div>
  <div class="mtab" id="mn-data" onclick="showTab('data');setMT('data')">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>Fichiers
  </div>
</nav>

<!-- MODAL -->
<div id="mo" onclick="if(event.target===this)closeModal()">
  <div class="modal">
    <div class="mo-t" id="mo-t"></div>
    <div class="mo-s" id="mo-s"></div>
    <div id="mo-b"></div>
    <div class="mbtns" id="mo-btns"></div>
  </div>
</div>
<div id="toast"></div>

<!-- SETTINGS MODAL -->
<div id="settings-modal" onclick="if(event.target===this)closeSettings()">
  <div class="settings-inner">
    <div class="settings-header">
      <div class="settings-title">⚙️ Paramètres IXA</div>
      <button onclick="closeSettings()" style="background:none;border:none;color:var(--mu);cursor:pointer;font-size:1.1rem;padding:4px">✕</button>
    </div>
    <div class="settings-tabs">
      <button class="stab act" id="stab-account" onclick="showStab('account')">👤 Compte</button>
      <button class="stab" id="stab-api" onclick="showStab('api')">🔑 API</button>
      <button class="stab" id="stab-sync" onclick="showStab('sync')">🔄 Sync</button>
      <button class="stab" id="stab-ui" onclick="showStab('ui')">🎨 Interface</button>
      <button class="stab" id="stab-voice" onclick="showStab('voice')">🎙️ Vocal</button>
      <button class="stab" id="stab-mem" onclick="showStab('mem')">🧠 Mémoire</button>
      <button class="stab" id="stab-sec" onclick="showStab('sec')">🔐 Sécurité</button>
    </div>
    <div class="settings-body">
      <!-- ACCOUNT -->
      <div id="stab-content-account" class="stab-pane act">
        <div class="sfield">
          <label>👤 Nom d'affichage</label>
          <input class="mi" id="s-dname" type="text" placeholder="Votre nom">
        </div>
        <div class="sfield">
          <label>🔑 Nouveau mot de passe (laisser vide pour ne pas changer)</label>
          <input class="mi" id="s-newpw" type="password" placeholder="Nouveau mot de passe…" autocomplete="new-password">
        </div>
        <div class="sfield">
          <label>😀 Avatar (emoji ou image)</label>
          <div style="display:flex;gap:8px;align-items:center">
            <input class="mi" id="s-avatar" type="text" placeholder="Emoji (ex: 👑)" style="flex:1">

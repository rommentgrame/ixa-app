function toggleWebSearch(){
  S.webEnabled=!S.webEnabled;
  const btn=document.getElementById('web-btn');
  if(btn)btn.classList.toggle('web-on',S.webEnabled);
  btn.title=S.webEnabled?'Recherche web ON':'Recherche web OFF';
  toast(S.webEnabled?'🌐 Recherche web activée':'🌐 Recherche web désactivée');
}
function updateWebBtn(){
  const btn=document.getElementById('web-btn');if(!btn)return;
  btn.classList.toggle('web-on',S.webEnabled);
}
function needsWebSearch(text){
  if(S.webEnabled)return true;
  return /actualit|news|aujourd'hui|maintenant|récent|2024|2025|prix|météo|bourse|résultat|score|match|élection|crypto|bitcoin|dernier|latest|current|today/i.test(text);
}
async function doWebSearch(query){
  if(!S.serperKey){
    try{
      const r=await fetch(`https://api.duckduckgo.com/?q=${encodeURIComponent(query)}&format=json&no_html=1&skip_disambig=1`);
      if(r.ok){
        const d=await r.json();let results='';
        if(d.AbstractText)results+=`Résumé : ${d.AbstractText}\n`;
        if(d.RelatedTopics?.length){results+='\nSujets connexes :\n';d.RelatedTopics.slice(0,5).forEach(t=>{if(t.Text)results+=`• ${t.Text}\n`;});}
        if(d.Answer)results+=`\nRéponse directe : ${d.Answer}`;
        return results||null;
      }
    }catch(e){}
    return null;
  }
  try{
    const r=await fetch('https://google.serper.dev/search',{
      method:'POST',
      headers:{'X-API-KEY':S.serperKey,'Content-Type':'application/json'},
      body:JSON.stringify({q:query,gl:'fr',hl:'fr',num:5})
    });
    if(!r.ok)return null;
    const d=await r.json();let results='';
    if(d.answerBox?.answer)results+=`Réponse directe : ${d.answerBox.answer}\n\n`;
    if(d.organic?.length){
      results+='Résultats de recherche :\n';
      d.organic.slice(0,5).forEach((item,i)=>{
        results+=`${i+1}. ${item.title}\n   ${item.snippet}\n   Source : ${item.link}\n\n`;
      });
    }
    return results||null;
  }catch(e){return null;}
}

/* ═══ SPEECH ═══ */
let _vOn=false;
function initSpeech(){
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;if(!SR)return;
  if(S.recognition)return; // Already init
  S.recognition=new SR();
  S.recognition.lang='fr-FR';S.recognition.interimResults=true;S.recognition.continuous=false;
  S.recognition.onresult=e=>{
    const txt=Array.from(e.results).map(r=>r[0].transcript).join('');
    const vtr=document.getElementById('vtr');if(vtr)vtr.textContent=txt;
    if(e.results[e.results.length-1].isFinal)onVoiceResult(txt);
  };
  S.recognition.onerror=e=>{
    console.error('Voice error',e.error);
    _vOn=false;resetVUI();
    if(e.error==='not-allowed')toast('❌ Microphone non autorisé — vérifiez les permissions','err');
  };
  S.recognition.onend=()=>{
    _vOn=false;
    const ob=document.getElementById('orb-box');if(ob)ob.classList.remove('listening');
  };
  populateVoiceList();
  if(S.synth.onvoiceschanged!==undefined)S.synth.onvoiceschanged=populateVoiceList;
}
function populateVoiceList(){
  const voices=S.synth.getVoices();
  const frVoices=voices.filter(v=>v.lang.startsWith('fr'));
  ['v-voice-sel','s-tts-voice'].forEach(id=>{
    const sel=document.getElementById(id);if(!sel)return;
    sel.innerHTML='';
    if(!frVoices.length){sel.innerHTML='<option value="-1">(Voix système)</option>';return;}
    frVoices.forEach((v,i)=>{
      const opt=document.createElement('option');opt.value=i;
      opt.textContent=(v.name.match(/natural|premium|enhanced/i)?'⭐ ':'')+v.name+' ('+v.lang+')';
      sel.appendChild(opt);
    });
    const bestIdx=frVoices.findIndex(v=>/natural|premium|enhanced/i.test(v.name));
    if(bestIdx>=0)sel.value=bestIdx;
  });
}
function updateVoiceSetting(){S.voiceIdx=parseInt(document.getElementById('v-voice-sel').value);}
function updateVoiceRate(v){S.voiceRate=parseFloat(v);const el=document.getElementById('v-rate-val');if(el)el.textContent=parseFloat(v).toFixed(1)+'×';}
function updateVoicePitch(v){S.voicePitch=parseFloat(v);const el=document.getElementById('v-pitch-val');if(el)el.textContent=parseFloat(v).toFixed(1);}
function getSelectedVoice(){
  const voices=S.synth.getVoices();
  const frV=voices.filter(v=>v.lang.startsWith('fr'));
  const sel=document.getElementById('v-voice-sel');
  const idx=sel?parseInt(sel.value):-1;
  if(idx>=0&&frV[idx])return frV[idx];
  return frV.find(v=>/natural|premium|enhanced/i.test(v.name))||frV[0]||null;
}
function toggleVoice(){
  initSpeech();
  if(!S.recognition){toast('❌ Reconnaissance vocale non supportée','err');return;}
  if(_vOn){S.recognition.abort();stopSpeech();_vOn=false;resetVUI();return;}
  stopSpeech();_vOn=true;
  const ob=document.getElementById('orb-box');if(ob)ob.classList.add('listening');
  const vst=document.getElementById('vst');if(vst)vst.textContent='IXA vous écoute…';
  const vtr=document.getElementById('vtr');if(vtr)vtr.textContent='';
  setVBtn('stop');
  try{S.recognition.start();}catch(e){_vOn=false;resetVUI();toast('❌ Erreur microphone: '+e.message,'err');}
}

// FIXED: Proper continuous voice conversation
async function onVoiceResult(text){
  _vOn=false;
  const ob=document.getElementById('orb-box');if(ob)ob.classList.remove('listening');
  const vst=document.getElementById('vst');if(vst)vst.textContent='IXA réfléchit…';
  setVBtn('start');

  // Show user message in voice view
  if(document.getElementById('v-show-msgs')?.checked){
    addVoiceMsg('usr',text);
  }
  // Also send to chat
  const reply=await handleSend(text);
  if(reply){
    if(document.getElementById('v-show-msgs')?.checked){
      addVoiceMsg('ixa',stripMd(reply).slice(0,300)+(reply.length>300?'…':''));
    }
    if(S.voiceRead&&S.tab==='voice'){
      const vst2=document.getElementById('vst');if(vst2)vst2.textContent='IXA répond…';
      speakChunked(stripMd(reply),()=>{
        if(S.tab==='voice'){
          if(S.voiceCont){
            const vst3=document.getElementById('vst');if(vst3)vst3.textContent='En attente…';
            // Proper restart with delay
            setTimeout(()=>{
              if(S.tab==='voice'&&!_vOn&&!S.loading){
                toggleVoice();
              }else{
                resetVUI();
              }
            },800);
          }else{
            resetVUI();
          }
        }
      });
    }else{
      resetVUI();
    }
  }else{
    resetVUI();
  }
}

function addVoiceMsg(role,text){
  const container=document.getElementById('voice-msgs');if(!container)return;
  const div=document.createElement('div');div.className='vms '+role;
  div.innerHTML=`<div class="vms-role">${role==='usr'?(S.user?.display_name||'Vous'):'IXA'}</div>${esc(text)}`;
  container.appendChild(div);container.scrollTop=container.scrollHeight;
}

function stripMd(t){
  return t.replace(/```[\s\S]*?```/g,'').replace(/#{1,6}\s/g,'').replace(/[*_`~\[\]]/g,'').replace(/<[^>]+>/g,'').replace(/\n{3,}/g,'\n').trim();
}
function speakChunked(text,onDone=null){
  stopSpeech();
  const sentences=text.match(/[^.!?\n]{1,180}[.!?\n]+|[^.!?\n]{1,180}$/g)||[text];
  S.voiceQueue=sentences.map(s=>s.trim()).filter(s=>s.length>2);
  S.voiceActive=true;S.voicePaused=false;
  document.getElementById('vpb').style.width='0%';
  speakNext(onDone);
}
function speakNext(onDone=null){
  if(!S.voiceQueue.length||!S.voiceActive){
    S.voiceActive=false;
    document.getElementById('vpb').style.width='100%';
    setTimeout(()=>{
      document.getElementById('vpb').style.width='0%';
      if(onDone)onDone();
      else if(S.tab==='voice')resetVUI();
    },1000);
    return;
  }
  const sentence=S.voiceQueue.shift();
  const u=new SpeechSynthesisUtterance(sentence);
  const frVoice=getSelectedVoice();
  if(frVoice)u.voice=frVoice;
  u.lang='fr-FR';u.rate=S.voiceRate;u.pitch=S.voicePitch;
  const total=S.voiceQueue.length+1;
  u.onend=()=>{if(S.voiceActive&&!S.voicePaused)speakNext(onDone);};
  u.onerror=()=>speakNext(onDone);
  const done=Math.round((1-S.voiceQueue.length/Math.max(total,1))*94);
  document.getElementById('vpb').style.width=done+'%';
  // Chrome workaround for TTS bug
  if(window.chrome)S.synth.cancel();
  S.synth.speak(u);
}
function stopSpeech(){S.voiceQueue=[];S.voiceActive=false;S.voicePaused=false;S.synth.cancel();document.getElementById('vpb').style.width='0%';}
function audioToggle(){
  if(S.voicePaused){S.voicePaused=false;S.synth.resume();document.getElementById('a-pp').textContent='⏸';document.getElementById('a-stat').textContent='Lecture…';}
  else{S.voicePaused=true;S.synth.pause();document.getElementById('a-pp').textContent='▶';document.getElementById('a-stat').textContent='En pause';}
}
function audioStop(){stopSpeech();const la=document.getElementById('laudio');if(la)la.style.display='none';}
function resetVUI(){
  _vOn=false;
  const ob=document.getElementById('orb-box');if(ob)ob.classList.remove('listening');
  const vst=document.getElementById('vst');if(vst)vst.textContent='En attente de vos instructions, '+(S.user?.display_name||'Tom');
  const vtr=document.getElementById('vtr');if(vtr)vtr.textContent='';
  const vpb=document.getElementById('vpb');if(vpb)vpb.style.width='0%';
  setVBtn('start');
}
function setVBtn(mode){
  const b=document.getElementById('vbtn');if(!b)return;
  if(mode==='stop')b.innerHTML=`<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg> Arrêter`;
  else b.innerHTML=`<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg> Activer IXA`;
}

/* ═══ FILES ═══ */
const IMG_EXT=['png','jpg','jpeg','gif','webp'];
function readFile(file,cb){
  const ext=file.name.split('.').pop().toLowerCase();
  const isImg=IMG_EXT.includes(ext);
  const isXL=['xlsx','xls'].includes(ext);
  const isPDF=ext==='pdf';
  const isDocx=['docx','doc'].includes(ext);

  if(isDocx&&typeof mammoth!=='undefined'){
    const r=new FileReader();r.readAsArrayBuffer(file);
    r.onload=async e=>{
      try{const result=await mammoth.extractRawText({arrayBuffer:e.target.result});cb({content:result.value,name:file.name,isImg:false,isPDF:false});}
      catch(err){const r2=new FileReader();r2.readAsText(file,'UTF-8');r2.onload=e2=>cb({content:e2.target.result,name:file.name,isImg:false,isPDF:false});r2.onerror=()=>cb({content:'[Erreur lecture]',name:file.name,isImg:false,isPDF:false});}
    };
    r.onerror=()=>cb({content:'[Erreur lecture DOCX]',name:file.name,isImg:false,isPDF:false});
  }else if(isXL){
    const r=new FileReader();r.readAsArrayBuffer(file);
    r.onload=e=>{
      try{
        const wb=XLSX.read(new Uint8Array(e.target.result),{type:'array'});let txt='';
        wb.SheetNames.forEach(sn=>{txt+=`=== Feuille: ${sn} ===\n${XLSX.utils.sheet_to_csv(wb.Sheets[sn])}\n\n`;});
        cb({content:txt.trim(),name:file.name,isImg:false,isPDF:false,isXL:true});
      }catch(err){cb({content:`[Erreur XLSX: ${err.message}]`,name:file.name,isImg:false,isPDF:false});}
    };
    r.onerror=()=>cb({content:'[Erreur lecture]',name:file.name,isImg:false,isPDF:false});
  }else if(isImg){
    const r=new FileReader();r.readAsDataURL(file);
    r.onload=e=>cb({dataURL:e.target.result,b64:e.target.result.split(',')[1],name:file.name,isImg:true,isPDF:false,content:null});
    r.onerror=()=>cb({content:'[Erreur image]',name:file.name,isImg:false,isPDF:false});
  }else if(isPDF){
    const r=new FileReader();r.readAsDataURL(file);
    r.onload=e=>cb({dataURL:e.target.result,b64:e.target.result.split(',')[1],name:file.name,isImg:false,isPDF:true,content:null});
    r.onerror=()=>cb({content:'[Erreur PDF]',name:file.name,isImg:false,isPDF:false});
  }else{
    const r=new FileReader();r.readAsText(file,'UTF-8');
    r.onload=e=>cb({content:e.target.result,name:file.name,isImg:false,isPDF:false});
    r.onerror=()=>cb({content:'[Erreur lecture]',name:file.name,isImg:false,isPDF:false});
  }
}
function handleFiles(input){
  Array.from(input.files).forEach(f=>{
    const ext=f.name.split('.').pop().toLowerCase();
    const isXL=['xlsx','xls'].includes(ext);
    const max=(IMG_EXT.includes(ext)?5:isXL?8:ext==='pdf'?12:4)*1024*1024;
    if(f.size>max){toast(`❌ Fichier trop grand : ${f.name}`,'err');return;}
    readFile(f,d=>{S.attachments.push({...d,fileType:f.type});renderAT();toast(`📎 ${f.name} ajouté`);});
  });
  input.value='';
  S.usageStats.docs++;saveStats();
}
function renderAT(){
  document.getElementById('at').innerHTML=S.attachments.map((a,i)=>`
    <div class="ach">${a.isImg?'🖼️':a.isPDF?'📑':a.isXL?'📗':'📄'} ${esc(a.name)}
      <span class="arm" onclick="rmAT(${i})">×</span></div>`).join('');
}
function rmAT(i){S.attachments.splice(i,1);renderAT();}

// Innovation: Paste images from clipboard
function onPaste(e){
  const items=e.clipboardData?.items;if(!items)return;
  for(const item of items){
    if(item.type.startsWith('image/')){
      const f=item.getAsFile();if(!f)continue;
      const ext=item.type.split('/')[1]||'png';
      const named=new File([f],'paste_'+Date.now()+'.'+ext,{type:item.type});
      readFile(named,d=>{S.attachments.push({...d,fileType:item.type});renderAT();toast('📋 Image collée !');});
    }
  }
}
function onGlobalPaste(e){
  if(document.activeElement&&document.activeElement.tagName==='TEXTAREA')return;
  if(document.activeElement&&document.activeElement.tagName==='INPUT')return;
  onPaste(e);
}

/* ═══ SEND + MODEL ROUTING ═══ */
async function handleSend(voiceText=null){
  if(S.loading)return null;
  const inp=document.getElementById('mi');
  let text=(voiceText!==null?voiceText:inp.value).trim();
  if(!text&&S.attachments.length===0)return null;
  document.getElementById('cmd-s').style.display='none';

  // Resolve /command
  let cmdAtts=[];
  for(const[cmd]of Object.entries(S.commands)){
    if(text===cmd||text.startsWith(cmd+' ')){
      cmdAtts=[{...S.commands[cmd]}];
      text=text.slice(cmd.length).trim()||'Analyse ce fichier en détail.';break;
    }
  }
  const atts=[...S.attachments,...cmdAtts];
  document.getElementById('welcome')?.remove();
  S.loading=true;document.getElementById('sbtn').disabled=true;

  const display=text||`Analyse: ${atts.map(a=>a.name).join(', ')}`;
  const ts=new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
  renderUserMsg(display,atts,true,ts);
  if(!voiceText){inp.value='';inp.style.height='auto';clearDraft();}

  const chat=S.chats.find(c=>c.id===S.cid);
  if(!chat){S.loading=false;document.getElementById('sbtn').disabled=false;return null;}
  if(!chat.messages.length&&text){chat.title=text.slice(0,48)+(text.length>48?'…':'');renderHist();}

  // Handle large files
  let finalAtts=[...atts];
  const bigFile=finalAtts.find(a=>!a.isImg&&!a.isPDF&&a.content&&a.content.length>9000);
  if(bigFile){
    if(!chat._chunks)chat._chunks={};
    chat._chunks[bigFile.name]={full:bigFile.content,idx:1,q:text};
    const trunc=bigFile.content.slice(0,9000)+`\n\n[…Fichier tronqué. Tapez "suite" pour la partie suivante.]`;
    finalAtts=finalAtts.map(a=>a===bigFile?{...a,content:trunc}:a);
  }
  if(text.toLowerCase().trim()==='suite'&&chat._chunks){
    const ck=Object.values(chat._chunks)[0];
    if(ck&&ck.idx*9000<ck.full.length){
      const next=ck.full.slice(ck.idx*9000,(ck.idx+1)*9000);
      const more=ck.full.length>(ck.idx+1)*9000;
      finalAtts=[{content:`Voici la suite du fichier :\n${next}${more?'\n\n[Tapez "suite" pour la partie suivante.]':''}`,name:'suite',isImg:false,isPDF:false}];
      ck.idx++;text=ck.q;
    }
  }

  let webContext='';
  if(needsWebSearch(text)){
    updateAst('web');
    webContext=await doWebSearch(text)||'';
  }

  S.attachments=[];renderAT();

  const chain=CHAINS[pickChain(text,finalAtts)];
  const reply=await callWithFallback(text,finalAtts,chat,chain,0,webContext);
  S.loading=false;document.getElementById('sbtn').disabled=false;
  updateAst(S.groqKey?'ok':'err');

  // Auto memory extraction
  if(reply&&text&&S.autoMemory){
    setTimeout(()=>extractMemoryFromReply(text,reply),2000);
  }
  // Update stats
  if(reply){S.usageStats.messages++;S.usageStats.chars+=text.length;saveStats();}
  return reply;
}

function hint(t){document.getElementById('mi').value=t;handleSend();}

function pickChain(text,atts){
  if(atts.some(a=>a.isImg||a.isPDF))return 'vision';
  const isDocGen=/\bcrée\b|\bgénère\b|\brédige\b|\bfais.*?(powerpoint|excel|pdf|word|rapport|cv|lettre|contrat|tableau|présentation)|powerpoint|xlsx?|word|rapport|cv\b|lettre|contrat|présentation/i.test(text);
  if(isDocGen)return 'doc';
  const hasDoc=atts.some(a=>a.content);
  if(hasDoc||text.length>500)return 'smart';
  // Use user's preferred model if set
  if(S.modelPref!=='auto')return 'fast';
  return 'fast';
}

function getPreferredModels(chain){
  if(S.modelPref!=='auto'&&!chain.includes(S.modelPref)){
    return [S.modelPref,...chain];
  }
  return chain;
}

async function callWithFallback(text,atts,chat,models,idx,webContext=''){
  const allModels=getPreferredModels(models);
  while(idx<allModels.length&&!isModelAvailable(allModels[idx])){idx++;}
  if(idx>=allModels.length){
    const waitMin=Object.values(_modelErrors).length?Math.ceil((Math.max(...Object.values(_modelErrors))-Date.now())/60000):1;
    renderMsg('assistant',`⏳ **Quota momentanément atteint.** Réessayez dans environ **${waitMin} minute${waitMin>1?'s':''}**.\n\n💡 *Astuce : activez le Dev Tier sur [console.groq.com](https://console.groq.com/settings/billing) pour augmenter vos limites.*`);
    return null;
  }
  const model=allModels[idx];
  let apiContent;
  const hasVision=atts.some(a=>a.isImg||a.isPDF);
  if(hasVision){
    const parts=[];
    atts.forEach(a=>{
      if((a.isImg||a.isPDF)&&a.dataURL)parts.push({type:'image_url',image_url:{url:a.dataURL}});
      else if(a.content)parts.push({type:'text',text:'=== '+a.name+' ===\n'+a.content.slice(0,4000)+'\n==='});
    });
    parts.push({type:'text',text:text||'Analyse ce contenu en détail.'});
    apiContent=parts;
  }else if(atts.length>0){
    const docBlock=atts.map(a=>'=== DOCUMENT: '+a.name+' ===\n'+(a.content||'[Contenu non disponible]').slice(0,8000)+'\n=== FIN '+a.name+' ===').join('\n\n');
    apiContent=docBlock+'\n\n--- INSTRUCTION ---\n'+(text||'Analyse ce document en détail.');
  }else{apiContent=text;}

  const estTok=Math.ceil(String(typeof apiContent==='string'?apiContent:JSON.stringify(apiContent)).length/3.5);
  const modelLimit=TPM[model]||5000;
  if(estTok>modelLimit*0.85&&idx+1<allModels.length)return callWithFallback(text,atts,chat,allModels,idx+1,webContext);

  const storedContent=typeof apiContent==='string'?(apiContent.length>800?apiContent.slice(0,800)+'…[doc]':apiContent):text;
  const ts=new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
  chat.messages.push({role:'user',content:storedContent,displayContent:text,apiContent,ts});
  saveLocal();
  const tid=showTyping();

  try{
    const sysPrompt=SYS(webContext);
    const isDocGen=/crée|génère|powerpoint|excel|rapport|word|pdf|cv|lettre/i.test(text);
    const maxToks=isDocGen?4000:2000;

    const res=await fetch('https://api.groq.com/openai/v1/chat/completions',{
      method:'POST',
      headers:{'Authorization':'Bearer '+S.groqKey,'Content-Type':'application/json'},
      body:JSON.stringify({
        model,
        messages:[
          {role:'system',content:sysPrompt},
          ...chat.messages.slice(0,-1).map(m=>({role:m.role,content:m.displayContent||m.content})),
          {role:'user',content:apiContent}
        ],
        max_tokens:maxToks,temperature:0.65,
      })
    });
    removeTyping(tid);
    if(!res.ok){
      const errData=await res.json().catch(()=>({}));
      const errMsg=errData.error?.message||'';
      chat.messages.pop();saveLocal();
      if(res.status===429){markModelError(model);return callWithFallback(text,atts,chat,allModels,idx+1,webContext);}
      if(res.status===503||errMsg.includes('decommissioned')||errMsg.includes('deprecated')||errMsg.includes('not found')||errMsg.includes('does not exist')){
        markModelError(model);return callWithFallback(text,atts,chat,allModels,idx+1,webContext);
      }
      if(res.status===401){updateApiSt(false);renderMsg('assistant','❌ **Clé API invalide.** Vérifiez dans Paramètres > API.');return null;}
      renderMsg('assistant','❌ Erreur API '+res.status+'. Veuillez réessayer.');return null;
    }
    const data=await res.json();
    const reply=data.choices?.[0]?.message?.content||'';
    if(!reply){chat.messages.pop();saveLocal();renderMsg('assistant','❌ Réponse vide. Réessayez.');return null;}
    renderMsg('assistant',reply,true,ts);
    chat.messages.push({role:'assistant',content:reply,displayContent:reply,ts});
    saveLocal();
    delete _modelErrors[model];
    // Debounced push to GitHub
    clearTimeout(S._pushTimeout);
    S._pushTimeout=setTimeout(()=>pushUsers(),3000);
    return reply;
  }catch(e){
    removeTyping(tid);chat.messages.pop();saveLocal();
    if(e.name==='TypeError')renderMsg('assistant','❌ **Pas de connexion.** Vérifiez votre réseau.');
    else renderMsg('assistant','❌ Erreur: '+e.message);
    return null;
  }
}

/* ═══ RENDER MESSAGES ═══ */
let _msgId=0;
function renderUserMsg(text,atts=[],addToHist=false,ts=''){
  const cont=document.getElementById('msgs');
  const div=document.createElement('div');div.className='message user';div.dataset.msgid=++_msgId;
  const avHtml=S.user?.avatarImg?`<img src="${S.user.avatarImg}" style="width:100%;height:100%;object-fit:cover;border-radius:50%">`:(S.user?.avatar||'👤');
  const ah=atts.map(a=>a.isImg?`<img src="${a.dataURL}" class="msg-img" alt="${esc(a.name)}">`:`<div class="msg-file">${a.isPDF?'📑':a.isXL?'📗':'📄'} ${esc(a.name)}</div>`).join('');
  const escapedText=esc(text);const mid=_msgId;
  const showTs=localStorage.getItem('ixa_timestamps')!=='false';
  div.innerHTML=`<div class="mav">${avHtml}</div><div class="mbody"><div class="mrole">${esc(S.user?.display_name||'Vous')}${showTs&&ts?`<span class="mtime">${ts}</span>`:''}</div>${ah}<div class="mc">${escapedText}</div>
    <div class="msg-actions"><button class="mact" onclick="copyMsg(${mid})">📋 Copier</button><button class="mact" onclick="retryMsg(${mid})">🔄 Réessayer</button><button class="mact" onclick="editMsg(${mid})">✏️ Modifier</button></div>
  </div>`;
  div.dataset.text=text;cont.appendChild(div);cont.scrollTop=cont.scrollHeight;return div;
}
function renderMsg(role,content,addToHist=false,ts=''){
  const cont=document.getElementById('msgs');
  const div=document.createElement('div');div.className=`message ${role==='user'?'user':'ass'}`;div.dataset.msgid=++_msgId;
  const avHtml=role==='user'?(S.user?.avatarImg?`<img src="${S.user.avatarImg}" style="width:100%;height:100%;object-fit:cover;border-radius:50%">`:S.user?.avatar||'👤'):'✦';
  const body=role==='assistant'?renderAI(content):`<div class="mc">${esc(content)}</div>`;
  const mid=_msgId;const showTs=localStorage.getItem('ixa_timestamps')!=='false';
  div.innerHTML=`<div class="mav">${avHtml}</div><div class="mbody"><div class="mrole">${role==='user'?(S.user?.display_name||'Vous'):'IXA'}${showTs&&ts?`<span class="mtime">${ts}</span>`:''}
  </div>${body}<div class="msg-actions"><button class="mact" onclick="copyMsg(${mid})">📋 Copier</button>${role==='assistant'?`<button class="mact" onclick="retryLast()">🔄 Régénérer</button><button class="mact" onclick="speakMsg(${mid})">🔊 Écouter</button>`:''}
  </div></div>`;
  div.dataset.rawContent=content;cont.appendChild(div);cont.scrollTop=cont.scrollHeight;
}
function speakMsg(mid){
  const el=document.querySelector(`[data-msgid="${mid}"]`);if(!el)return;
  const text=el.dataset.rawContent||el.querySelector('.mc')?.textContent||'';
  speakChunked(stripMd(text));toast('🔊 Lecture en cours…');
}
function copyMsg(mid){
  const el=document.querySelector(`[data-msgid="${mid}"]`);if(!el)return;
  const text=el.dataset.rawContent||el.dataset.text||el.querySelector('.mc')?.textContent||'';
  navigator.clipboard.writeText(text).then(()=>toast('📋 Copié !','ok'));
}
function retryMsg(mid){
  const el=document.querySelector(`[data-msgid="${mid}"]`);if(!el)return;
  const text=el.dataset.text||el.querySelector('.mc')?.textContent||'';
  if(text){document.getElementById('mi').value=text;handleSend();}
}
function editMsg(mid){
  const el=document.querySelector(`[data-msgid="${mid}"]`);if(!el)return;
  const text=el.dataset.text||el.querySelector('.mc')?.textContent||'';
  const inp=document.getElementById('mi');
  inp.value=text;inp.focus();inp.style.height='auto';inp.style.height=Math.min(inp.scrollHeight,150)+'px';
  el.remove();
  const chat=S.chats.find(c=>c.id===S.cid);if(!chat)return;
  if(chat.messages.length>=2)chat.messages.splice(-2,2);
  else if(chat.messages.length===1)chat.messages.pop();
  saveLocal();
}
function retryLast(){
  const chat=S.chats.find(c=>c.id===S.cid);if(!chat||!chat.messages.length)return;
  const lastAssIdx=chat.messages.map(m=>m.role).lastIndexOf('assistant');
  if(lastAssIdx>=0)chat.messages.splice(lastAssIdx,1);
  const lastUser=chat.messages.filter(m=>m.role==='user').slice(-1)[0];
  if(!lastUser)return;
  saveLocal();
  const msgs=document.getElementById('msgs');
  const msgDivs=msgs.querySelectorAll('.message.ass');
  msgDivs[msgDivs.length-1]?.remove();
  S.loading=false;document.getElementById('sbtn').disabled=false;
  handleSend(lastUser.displayContent||lastUser.content);
}
function showTyping(){
  const tid='t'+Date.now();const cont=document.getElementById('msgs');
  const div=document.createElement('div');div.className='message ass';div.id=tid;
  div.innerHTML=`<div class="mav">✦</div><div class="mbody"><div class="mrole">IXA</div><div class="typing"><div class="td"></div><div class="td"></div><div class="td"></div></div></div>`;
  cont.appendChild(div);cont.scrollTop=cont.scrollHeight;return tid;
}
function removeTyping(id){document.getElementById(id)?.remove();}

/* ═══ MARKDOWN RENDERER ═══ */
function renderAI(raw){
  // Pass 1: document blocks
  const re=/```document(?::(\w+))?\n([\s\S]*?)```/g;
  let html='',li=0,m,foundDoc=false;
  while((m=re.exec(raw))!==null){
    foundDoc=true;
    const before=raw.slice(li,m.index).trim();
    if(before)html+=`<div class="mc">${md(before)}</div>`;
    const dtype=(m[1]||'document').toLowerCase();const dcontent=m[2].trim();
    const did='doc_'+Date.now()+'_'+Math.random().toString(36).slice(2,7);
    window.__docs[did]={type:dtype,content:dcontent};
    html+=makeDocCard(did,dtype,dcontent);li=m.index+m[0].length;
  }
  const rem=raw.slice(li).trim();if(rem)html+=`<div class="mc">${md(rem)}</div>`;
  if(foundDoc)return html;
  // Pass 2: auto-detect JSON blocks
  const jsonBlockRe=/```(?:json)?\s*\n?([\s\S]*?)```/g;
  let rhtml='',jli=0,jm,intercepted=false;
  while((jm=jsonBlockRe.exec(raw))!==null){
    const jstr=jm[1].trim();
    try{
      const parsed=JSON.parse(jstr);
      if(parsed.slides&&Array.isArray(parsed.slides)&&parsed.slides.length>0){
        intercepted=true;const bef=raw.slice(jli,jm.index).trim();
        if(bef)rhtml+=`<div class="mc">${md(bef)}</div>`;
        const did='doc_'+Date.now()+'_'+Math.random().toString(36).slice(2,7);
        window.__docs[did]={type:'powerpoint',content:jstr};rhtml+=makeDocCard(did,'powerpoint',jstr);
        jli=jm.index+jm[0].length;continue;
      }
      if(parsed.sheets&&Array.isArray(parsed.sheets)&&parsed.sheets.length>0){
        intercepted=true;const bef=raw.slice(jli,jm.index).trim();
        if(bef)rhtml+=`<div class="mc">${md(bef)}</div>`;
        const did='doc_'+Date.now()+'_'+Math.random().toString(36).slice(2,7);
        window.__docs[did]={type:'excel',content:jstr};rhtml+=makeDocCard(did,'excel',jstr);
        jli=jm.index+jm[0].length;continue;
      }
    }catch(e){}
  }
  if(intercepted){const remJ=raw.slice(jli).trim();if(remJ)rhtml+=`<div class="mc">${md(remJ)}</div>`;return rhtml;}
  return `<div class="mc">${md(raw)}</div>`;
}
function md(raw){
  if(!raw)return '';let t=raw;
  const codeMap={};
  t=t.replace(/```(\w*)\n?([\s\S]*?)```/g,(_,lang,code)=>{
    const id='cb_'+Math.random().toString(36).slice(2,8);const bid='cb_b_'+id;
    codeMap[id]=`<div class="cb"><div class="cbh"><span class="cbl">${lang||'text'}</span><button class="cpb" id="${bid}" onclick="copyCode('${bid}')">Copier</button></div><pre><code>${esc(code.trim())}</code></pre></div>`;
    return `\x00CODE${id}\x00`;
  });
  const icMap={};
  t=t.replace(/`([^`\n]+)`/g,(_,c)=>{const id='ic_'+Math.random().toString(36).slice(2,8);icMap[id]=`<code>${esc(c)}</code>`;return `\x00IC${id}\x00`;});
  t=t.replace(/^#{4,}\s+(.+)$/gm,'<h3>$1</h3>').replace(/^#{3}\s+(.+)$/gm,'<h3>$1</h3>').replace(/^#{2}\s+(.+)$/gm,'<h2>$1</h2>').replace(/^#\s+(.+)$/gm,'<h1>$1</h1>');
  t=t.replace(/^-{3,}$/gm,'<hr>').replace(/^>\s+(.+)$/gm,'<blockquote>$1</blockquote>');
  t=t.replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>').replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>').replace(/__(.+?)__/g,'<strong>$1</strong>').replace(/\*([^*\n]+?)\*/g,'<em>$1</em>').replace(/_([^_\n]+?)_/g,'<em>$1</em>');
  t=t.replace(/~~(.+?)~~/g,'<del>$1</del>');
  // Tables
  t=t.replace(/(\|.+\|\n\|[-|:\s]+\|\n(?:\|.+\|\n?)*)/g,match=>{
    const lines=match.trim().split('\n').filter(l=>l.trim()&&!/^\|[-|:\s]+\|$/.test(l));
    if(lines.length<2)return match;
    const header=lines[0].split('|').filter((_,i,a)=>i>0&&i<a.length-1).map(h=>`<th>${md(h.trim())}</th>`).join('');
    const rows=lines.slice(1).map(l=>`<tr>${l.split('|').filter((_,i,a)=>i>0&&i<a.length-1).map(c=>`<td>${md(c.trim())}</td>`).join('')}</tr>`).join('');
    return `<table><thead><tr>${header}</tr></thead><tbody>${rows}</tbody></table>`;
  });
  // Lists
  t=t.replace(/((?:^(?:\s*[-*+]|\d+\.)\s.+\n?)+)/gm,match=>{
    const isOl=/^\s*\d+\./.test(match);const tag=isOl?'ol':'ul';
    const items=match.trim().split('\n').map(l=>l.replace(/^\s*(?:[-*+]|\d+\.)\s/,'').trim());
    return `<${tag}>${items.map(i=>`<li>${md(i)}</li>`).join('')}</${tag}>`;
  });
  // Links
  t=t.replace(/\[([^\]]+)\]\(([^)]+)\)/g,'<a href="$2" target="_blank" rel="noopener">$1</a>');
  // Paragraphs
  t=t.split('\n\n').map(p=>p.trim()).filter(Boolean).map(p=>{
    if(/^<(h[1-6]|ul|ol|table|blockquote|hr|div|pre)/.test(p))return p;
    return `<p>${p.replace(/\n/g,'<br>')}</p>`;
  }).join('\n');
  Object.entries(codeMap).forEach(([id,html])=>{t=t.replace(new RegExp(`\x00CODE${id}\x00`,'g'),html);});
  Object.entries(icMap).forEach(([id,html])=>{t=t.replace(new RegExp(`\x00IC${id}\x00`,'g'),html);});
  return t;
}
function md2htmlExport(raw){return md(raw);}
function copyCode(bid){
  const btn=document.getElementById(bid);if(!btn)return;
  const code=btn.closest('.cb')?.querySelector('code')?.textContent||'';
  navigator.clipboard.writeText(code).then(()=>{
    btn.textContent='✅ Copié';btn.classList.add('ok');
    setTimeout(()=>{btn.textContent='Copier';btn.classList.remove('ok');},1800);
  });
}
function makeDocCard(id,dtype,content){
  const lines=content.split('\n').length;const chars=content.length;
  const icons={powerpoint:'📊',excel:'📗',pdf:'📄',word:'📝',document:'📋'};
  const labels={powerpoint:'Présentation PowerPoint',excel:'Tableau Excel',pdf:'Document PDF',word:'Document Word',document:'Document'};
  const isPPT=dtype==='powerpoint';const isXL=dtype==='excel';const isPDF=dtype==='pdf';const isWord=dtype==='word'||dtype==='document';
  return `<div class="doc-card"><div class="dch"><div class="dci">${icons[dtype]||'📋'}</div><div><div class="dct">${labels[dtype]||dtype}</div><div class="dcs">${lines} lignes · ${chars} caractères</div></div></div>
  <div class="dca">
    ${isPPT?`<button class="dcb dl" onclick="genPPTX('${id}')">⬇ PowerPoint</button>`:''}
    ${isXL?`<button class="dcb dl" onclick="genXLSX('${id}')">⬇ Excel</button>`:''}
    ${isPDF?`<button class="dcb dl" onclick="genPDF('${id}')">⬇ PDF</button>`:''}
    ${isWord?`<button class="dcb dl" onclick="genWord('${id}')">⬇ Word</button>`:''}
    <button class="dcb pv" onclick="prvDoc('${id}')">👁 Aperçu</button>
    <button class="dcb pv" onclick="cpDoc('${id}')">📋 Copier</button>
  </div></div>`;
}
function getDoc(id){return window.__docs[id]||null;}
function cpDoc(id){const d=getDoc(id);if(!d)return;navigator.clipboard.writeText(d.content).then(()=>toast('📋 Copié !','ok'));}
function prvDoc(id){
  const d=getDoc(id);if(!d)return;
  const w=window.open('','_blank',`width=${Math.min(900,screen.width)},height=${Math.min(700,screen.height)}`);
  if(!w){toast('❌ Popup bloqué','err');return;}
  w.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><style>body{font-family:'Segoe UI',sans-serif;padding:30px;max-width:800px;margin:auto;line-height:1.7;color:#1a1a2e;background:#f8f8ff}pre{background:#f0f0ff;padding:15px;border-radius:8px;overflow-x:auto;font-size:13px}code{background:#eeeeff;padding:2px 5px;border-radius:3px}h1,h2,h3{color:#6c5ce7}table{width:100%;border-collapse:collapse}th,td{border:1px solid #ddd;padding:8px}th{background:#6c5ce7;color:white}blockquote{border-left:4px solid #6c5ce7;padding-left:14px;color:#555}</style></head><body><h1>Aperçu du document</h1><hr>${md2htmlExport(d.content)}</body></html>`);
  w.document.close();
}
function dlBlob(blob,name){const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=name;a.click();URL.revokeObjectURL(a.href);}
function genWord(id){
  const d=getDoc(id);if(!d)return;
  const html=`<!DOCTYPE html><html><head><meta charset="UTF-8"><style>body{font-family:Calibri,sans-serif;font-size:11pt;margin:2.5cm;line-height:1.6}h1{font-size:16pt;color:#2c3e50}h2{font-size:13pt;color:#34495e}h3{font-size:11pt;color:#555}table{border-collapse:collapse;width:100%}th,td{border:1px solid #bdc3c7;padding:7px}th{background:#ecf0f1;font-weight:bold}</style></head><body>${md2htmlExport(d.content)}</body></html>`;
  dlBlob(new Blob([html],{type:'application/msword;charset=utf-8'}),`ixa_${d.type}.doc`);
  toast('✅ Word téléchargé !','ok');
}
function genPDF(id){
  const d=getDoc(id);if(!d)return;
  const bodyContent=md2htmlExport(d.content);
  const html=`<!DOCTYPE html><html><head><meta charset="UTF-8"><style>@page{margin:2cm}body{font-family:Georgia,serif;font-size:11pt;max-width:800px;margin:40px auto;padding:0 20px;line-height:1.8}h1{font-size:20pt;color:#6c5ce7;border-bottom:3px solid #6c5ce7;padding-bottom:10px}h2{font-size:14pt;color:#333}table{width:100%;border-collapse:collapse}th{background:#6c5ce7;color:#fff;padding:8px}td{border:1px solid #ccc;padding:7px}.no-print{background:#6c5ce7;color:#fff;padding:12px 20px;border-radius:8px;margin-bottom:24px;display:flex;align-items:center;gap:12px}.no-print button{background:#fff;color:#6c5ce7;border:none;padding:7px 16px;border-radius:6px;cursor:pointer;font-weight:700}@media print{.no-print{display:none!important}}</style></head><body>
  <div class="no-print">📄 <span>Ctrl+P → <strong>"Enregistrer en PDF"</strong></span><button onclick="window.print()">🖨️ Imprimer</button></div>
  ${bodyContent}
  </body></html>`;
  const w=window.open('','_blank');if(!w){toast('❌ Popup bloqué','err');return;}
  w.document.write(html);w.document.close();toast('✅ PDF ouvert — Ctrl+P pour télécharger','ok');
}
function genXLSX(id){
  const d=getDoc(id);if(!d)return;
  try{
    let data;try{data=JSON.parse(d.content);}catch(e){const lines=d.content.trim().split('\n').filter(l=>l.trim());const rows=lines.map(l=>l.split(/[,\t|]/).map(c=>c.trim()));data={sheets:[{name:'Données',headers:rows[0]||[],rows:rows.slice(1)}]};}
    const wb=XLSX.utils.book_new();const sheets=data.sheets||[{name:'Feuille1',headers:[],rows:[]}];
    sheets.forEach(s=>{
      const wsData=[];if(s.headers?.length)wsData.push(s.headers);(s.rows||[]).forEach(r=>wsData.push(Array.isArray(r)?r:Object.values(r)));
      const ws=XLSX.utils.aoa_to_sheet(wsData);
      const colW=wsData.reduce((acc,row)=>{row.forEach((cell,i)=>{acc[i]=Math.max(acc[i]||0,String(cell||'').length);});return acc;},[]);
      ws['!cols']=colW.map(w=>({wch:Math.min(w+2,40)}));
      XLSX.utils.book_append_sheet(wb,ws,s.name||'Feuille');
    });
    XLSX.writeFile(wb,`ixa_${d.type}.xlsx`);toast('✅ Excel téléchargé !','ok');
  }catch(e){toast('❌ Erreur Excel: '+e.message,'err');}
}
function genPPTX(id){
  const d=getDoc(id);if(!d)return;toast('⏳ Génération PowerPoint…');
  try{
    let data;try{data=JSON.parse(d.content);}catch(e){data={title:'Présentation IXA',slides:[{title:'Contenu',content:d.content,bullets:[]}]};}
    const pptx=new PptxGenJS();pptx.layout='LAYOUT_WIDE';pptx.author='IXA';pptx.title=data.title||'Présentation IXA';
    const C={bg:'0F0F1E',acc:'7C6FE0',acc2:'E040FB',wh:'FFFFFF',lt:'E6E6F0',mu:'8888AA',dk:'181835'};
    (data.slides||[]).forEach((sl,i)=>{
      const slide=pptx.addSlide();
      if(i===0){
        slide.addShape(pptx.ShapeType.rect,{x:0,y:0,w:'100%',h:'100%',fill:{type:'gradient',stops:[{position:0,color:C.bg},{position:100,color:'1A1A3A'}]}});
        slide.addShape(pptx.ShapeType.rect,{x:0,y:0,w:'100%',h:0.08,fill:{color:C.acc}});
        slide.addShape(pptx.ShapeType.rect,{x:0,y:7.42,w:'100%',h:0.08,fill:{color:C.acc2}});
        slide.addText(sl.title||data.title||'',{x:0.5,y:1.8,w:12,h:1.4,fontSize:36,bold:true,color:C.wh,fontFace:'Arial',align:'center'});
        if(sl.content)slide.addText(sl.content,{x:1,y:3.4,w:11,h:1.2,fontSize:18,color:C.lt,fontFace:'Arial',align:'center'});
        if(sl.bullets?.length){const bt=sl.bullets.map(b=>({text:'▸ '+b,options:{color:C.lt,fontSize:14,breakLine:true}}));slide.addText(bt,{x:2,y:4.8,w:9,h:2,fontFace:'Arial',valign:'top'});}
        slide.addText(`IXA — ${new Date().toLocaleDateString('fr-FR')}`,{x:0,y:7.0,w:'100%',h:0.35,fontSize:11,color:C.mu,fontFace:'Arial',align:'center'});
      }else{
        slide.addShape(pptx.ShapeType.rect,{x:0,y:0,w:'100%',h:'100%',fill:{color:C.bg}});
        slide.addShape(pptx.ShapeType.rect,{x:0,y:0,w:'100%',h:0.06,fill:{color:C.acc}});
        slide.addShape(pptx.ShapeType.rect,{x:0,y:0,w:0.06,h:'100%',fill:{type:'gradient',stops:[{position:0,color:C.acc},{position:100,color:C.acc2}]}});
        slide.addShape(pptx.ShapeType.rect,{x:0.2,y:0.15,w:12.4,h:0.9,fill:{color:C.dk},rounding:true});
        slide.addText(sl.title||'',{x:0.4,y:0.2,w:12,h:0.8,fontSize:22,bold:true,color:C.wh,fontFace:'Arial',valign:'middle'});
        slide.addText(`${i+1}/${data.slides.length}`,{x:11.8,y:7.1,w:0.8,h:0.35,fontSize:9,color:C.mu,align:'center',fontFace:'Arial'});
        let yPos=1.3;
        if(sl.content){slide.addText(sl.content,{x:0.4,y:yPos,w:12.4,h:0.7,fontSize:14,color:C.lt,fontFace:'Arial',wrap:true});yPos+=0.9;}
        if(sl.bullets?.length){
          sl.bullets.forEach((b,bi)=>{
            slide.addShape(pptx.ShapeType.rect,{x:0.4,y:yPos+bi*0.55,w:12,h:0.46,fill:{color:bi%2===0?C.dk:'0D0D20'},rounding:true});
            slide.addText(`▸ ${b}`,{x:0.6,y:yPos+bi*0.55,w:11.8,h:0.46,fontSize:13,color:bi%2===0?C.wh:C.lt,fontFace:'Arial',valign:'middle',wrap:true});
          });
        }
      }
    });
    pptx.writeFile({fileName:`ixa_${(data.title||'presentation').replace(/[^a-zA-Z0-9]/g,'_')}.pptx`}).then(()=>toast('✅ PowerPoint téléchargé !','ok')).catch(e=>toast('❌ Erreur: '+e.message,'err'));
  }catch(e){toast('❌ Erreur PPTX: '+e.message,'err');}
}

/* ═══ INPUT HANDLING ═══ */
function onInput(el){
  el.style.height='auto';el.style.height=Math.min(el.scrollHeight,150)+'px';
  showCmdSuggest(el.value);
  // Auto-draft save
  clearTimeout(S.draftSaveTimeout);
  S.draftSaveTimeout=setTimeout(()=>{
    if(el.value.trim()&&el.value.length>3){
      S.draftText=el.value;
      localStorage.setItem('ixa_draft_'+S.cid,el.value);
      const di=document.getElementById('draft-indicator');if(di)di.textContent='💾 Brouillon sauvegardé';
      setTimeout(()=>{const di=document.getElementById('draft-indicator');if(di)di.textContent='';},2000);
    }
  },1500);
}
function clearDraft(){
  S.draftText='';
  if(S.cid)localStorage.removeItem('ixa_draft_'+S.cid);
  const di=document.getElementById('draft-indicator');if(di)di.textContent='';
}
function loadDraft(){
  if(!S.cid)return;
  const d=localStorage.getItem('ixa_draft_'+S.cid);
  if(d){const inp=document.getElementById('mi');if(inp&&!inp.value)inp.value=d;}
}
function onKey(e){
  if(e.key==='Enter'&&!e.shiftKey&&!e.ctrlKey){e.preventDefault();handleSend();}
}
function showCmdSuggest(val){
  const box=document.getElementById('cmd-s');if(!box)return;
  if(!val.startsWith('/')||val.includes(' ')){box.style.display='none';return;}
  const m=Object.entries(S.commands).filter(([c])=>c.startsWith(val));
  if(!m.length){box.style.display='none';return;}
  box.style.display='flex';
  box.innerHTML=m.map(([c,d])=>`<div class="csi" onclick="selectCmd('${esc(c)}')"><span class="cmd">${esc(c)}</span><span class="fn">${esc(d.desc||d.name||'')}</span></div>`).join('');
}
function selectCmd(cmd){document.getElementById('mi').value=cmd+' ';document.getElementById('cmd-s').style.display='none';document.getElementById('mi').focus();}

/* ═══ COMMANDS (Raccourcis) ═══ */
function renderCmds(){
  const list=document.getElementById('fcmd-list');if(!list)return;
  const entries=Object.entries(S.commands);
  list.innerHTML=entries.length?entries.map(([cmd,d])=>`
    <div class="fi2">
      <div class="fi2-badge">${esc(cmd)}</div>
      <div class="fi2-name">${esc(d.name||d.desc||'Fichier')}</div>
      <div class="fi2-acts">
        <button class="fi2b" onclick="useCmdInChat('${esc(cmd)}')" title="Utiliser">💬</button>
        <button class="fi2b d" onclick="deleteCmd('${esc(cmd)}')" title="Supprimer">🗑</button>
      </div>
    </div>`).join(''):'<div class="cmd-empty">Aucun raccourci. Ajoutez-en un !</div>';
}
function useCmdInChat(cmd){
  showTab('chat');setMT('chat');
  document.getElementById('mi').value=cmd+' ';document.getElementById('mi').focus();
}
function deleteCmd(cmd){
  delete S.commands[cmd];saveLocal();renderCmds();toast('🗑 Raccourci supprimé');
}
function openAddCmd(){
  openModal('➕ Ajouter un raccourci fichier',
    `<div style="display:flex;flex-direction:column;gap:10px">
      <div><label style="font-size:.75rem;color:var(--mu);display:block;margin-bottom:4px">Commande (commence par /)</label><input class="mi" id="nc-cmd" placeholder="/mon-fichier" onkeydown="if(event.key==='Enter')addCmd()"></div>
      <div><label style="font-size:.75rem;color:var(--mu);display:block;margin-bottom:4px">Fichier à associer</label>
        <input type="file" id="nc-file" style="display:none" accept=".txt,.md,.csv,.json,.xlsx,.docx,.pdf,.py,.js,.html" onchange="onCmdFileChange(this)">
        <button class="mdb can" onclick="document.getElementById('nc-file').click()" style="width:100%">📂 Choisir un fichier</button>
        <div id="nc-fn" style="font-size:.73rem;color:var(--mu);margin-top:5px"></div>
      </div>
      <div><label style="font-size:.75rem;color:var(--mu);display:block;margin-bottom:4px">Description (optionnel)</label><input class="mi" id="nc-desc" placeholder="Ma description…"></div>
    </div>`,
    [{label:'Annuler',cls:'can',cb:'closeModal()'},{label:'Ajouter',cls:'cfm',cb:'addCmd()'}]
  );
}
let _pendingCmdFile=null;
function onCmdFileChange(inp){
  if(!inp.files.length)return;
  const f=inp.files[0];
  readFile(f,d=>{_pendingCmdFile=d;const nfn=document.getElementById('nc-fn');if(nfn)nfn.textContent='✅ '+f.name;});
}
function addCmd(){
  const cmd=(document.getElementById('nc-cmd')?.value||'').trim();
  const desc=(document.getElementById('nc-desc')?.value||'').trim();
  if(!cmd.startsWith('/')){toast('❌ La commande doit commencer par /','err');return;}
  if(!_pendingCmdFile){toast('❌ Sélectionnez un fichier','err');return;}
  S.commands[cmd]={..._pendingCmdFile,desc};_pendingCmdFile=null;
  saveLocal();renderCmds();closeModal();toast(`✅ Raccourci ${cmd} créé !`,'ok');
}

/* ═══ USER MANAGEMENT ═══ */
function openUserMgmt(){
  const rows=S.allUsers.users.map(u=>`
    <div style="display:flex;align-items:center;gap:9px;padding:9px 11px;background:var(--c1);border:1px solid var(--bd2);border-radius:9px;font-size:.79rem">
      <div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(120deg,var(--a),var(--a2));display:flex;align-items:center;justify-content:center;font-size:.75rem;flex-shrink:0">${u.avatar||'👤'}</div>
      <div style="flex:1;min-width:0"><div style="font-weight:600;color:var(--tx)">${esc(u.display_name||u.username)}</div><div style="color:var(--mu);font-size:.7rem">@${esc(u.username)} · ${u.role==='admin'?'👑 Admin':'👤 User'}</div></div>
      ${u.id!==S.user.id?`<button class="mdb del" onclick="deleteUser('${u.id}')" style="font-size:.7rem;padding:4px 8px">Supprimer</button>`:'<span style="font-size:.7rem;color:var(--ok)">Vous</span>'}
    </div>`).join('');
  openModal('👥 Gestion Utilisateurs',
    rows+`<div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--bd2);display:flex;flex-direction:column;gap:8px">
      <div style="font-weight:600;font-size:.83rem">Ajouter un utilisateur</div>
      <input class="mi" id="nu-user" placeholder="Identifiant" autocomplete="off">
      <input class="mi" id="nu-pass" type="password" placeholder="Mot de passe" autocomplete="new-password">
      <input class="mi" id="nu-name" placeholder="Nom affiché">
      <select class="mi" id="nu-role"><option value="user">Utilisateur</option><option value="admin">Admin</option></select>
    </div>`,
    [{label:'Fermer',cls:'can',cb:'closeModal()'},{label:'＋ Ajouter',cls:'cfm',cb:'addUser()'}]
  );
}
function addUser(){
  const un=(document.getElementById('nu-user')?.value||'').trim().toLowerCase();
  const pw=(document.getElementById('nu-pass')?.value||'').trim();
  const nm=(document.getElementById('nu-name')?.value||'').trim();
  const rl=document.getElementById('nu-role')?.value||'user';
  if(!un||!pw){toast('❌ Identifiant et mot de passe requis','err');return;}
  if(S.allUsers.users.find(u=>u.username===un)){toast('❌ Identifiant déjà utilisé','err');return;}
  const newUser={id:'u'+Date.now(),username:un,password:pw,display_name:nm||un,role:rl,avatar:'👤',avatarImg:null,conversations:[],commands:{},memory:[`${nm||un} est un utilisateur du système IXA`],permissions:{canSearch:true,canCreateDocs:true,canManageUsers:rl==='admin'}};
  S.allUsers.users.push(newUser);localStorage.setItem('ixa_users',JSON.stringify(S.allUsers));
  setTimeout(()=>pushUsers(),500);closeModal();toast(`✅ Utilisateur ${un} créé !`,'ok');
}
function deleteUser(id){
  if(id===S.user.id){toast('❌ Impossible de supprimer votre propre compte','err');return;}
  if(!confirm('Supprimer cet utilisateur ?'))return;
  S.allUsers.users=S.allUsers.users.filter(u=>u.id!==id);
  localStorage.setItem('ixa_users',JSON.stringify(S.allUsers));
  setTimeout(()=>pushUsers(),500);closeModal();toast('✅ Utilisateur supprimé');openUserMgmt();
}

/* ═══ LEARN MODE (FIXED) ═══ */
function lDrop(e){e.preventDefault();document.getElementById('ldrop').classList.remove('drag');const f=e.dataTransfer?.files?.[0];if(!f)return;learnLoad({files:[f]});}
function learnLoad(input){
  const f=input.files?.[0]||input;if(!f)return;
  if(f.size>15*1024*1024){toast('❌ Fichier trop grand (max 15MB)','err');return;}
  readFile(f,d=>{
    S.learnDoc={name:f.name,content:d.content||null,isImg:d.isImg,isPDF:d.isPDF,dataURL:d.dataURL,wordCount:(d.content||'').split(/\s+/).filter(Boolean).length,fileSize:f.size};
    S.learnChatHistory=[];
    document.getElementById('ldrop').style.display='none';
    const di=document.getElementById('ldoc');di.style.display='flex';
    document.getElementById('ldoc-nm').innerHTML=`📄 ${esc(f.name)} ${d.isImg?'<span style="font-size:.7rem;color:var(--inf)">🖼️</span>':d.isPDF?'<span style="font-size:.7rem;color:var(--inf)">📑</span>':''}`;
    const meta=[];
    if(!d.isImg&&!d.isPDF)meta.push(`${S.

/* ═══ THEME ═══ */
function applyTheme(){
  if(S.theme==='system'){
    const dark=window.matchMedia('(prefers-color-scheme: dark)').matches;
    document.body.classList.toggle('light',!dark);
  }else{document.body.classList.toggle('light',S.theme==='light');}
  const btn=document.getElementById('theme-btn');
  if(btn)btn.textContent=S.theme==='light'?'🌙':'☀️';
}
function toggleTheme(){
  S.theme=S.theme==='dark'?'light':'dark';
  localStorage.setItem('ixa_theme',S.theme);applyTheme();
}
function setTheme(t){
  S.theme=t;localStorage.setItem('ixa_theme',t);applyTheme();
  ['dark','light','sys'].forEach(n=>{
    const b=document.getElementById('theme-'+n+'-btn');
    if(b)b.style.background=n===t.replace('system','sys')?'var(--a)':'';
    if(b)b.style.color=n===t.replace('system','sys')?'#fff':'';
  });
}

// Innovation: Accent color customization
function setAccentColor(c1,c2,el){
  document.querySelectorAll('.color-opt').forEach(o=>o.classList.remove('act'));
  if(el)el.classList.add('act');
  document.documentElement.style.setProperty('--a',c1);
  document.documentElement.style.setProperty('--a2',c2);
  document.documentElement.style.setProperty('--glow',c1.replace('#','rgba(')+',0.3)'.replace('rgba(','rgba('+parseInt(c1.slice(1,3),16)+','+parseInt(c1.slice(3,5),16)+','+parseInt(c1.slice(5,7),16)+','));
  localStorage.setItem('ixa_accent',JSON.stringify([c1,c2]));
  toast('🎨 Couleur appliquée !');
}
// Load saved accent color
function loadAccentColor(){
  try{
    const ac=JSON.parse(localStorage.getItem('ixa_accent'));
    if(ac&&ac.length===2){
      document.documentElement.style.setProperty('--a',ac[0]);
      document.documentElement.style.setProperty('--a2',ac[1]);
    }
  }catch(e){}
}

// Innovation: Focus mode
function toggleFocusMode(){
  S.focusMode=!S.focusMode;
  document.body.classList.toggle('focus-mode',S.focusMode);
  toast(S.focusMode?'🎯 Mode focus activé':'🎯 Mode focus désactivé');
}

/* ═══ SETTINGS ═══ */
function openSettings(tab='account'){
  const m=document.getElementById('settings-modal');m.classList.add('open');
  showStab(tab);
  // Pre-fill values
  if(S.user){
    const dn=document.getElementById('s-dname');if(dn)dn.value=S.user.display_name||'';
    const av=document.getElementById('s-avatar');if(av)av.value=S.user.avatar||'';
  }
  const sg=document.getElementById('s-groq');if(sg&&S.groqKey)sg.value=S.groqKey;
  const ss=document.getElementById('s-serper');if(ss&&S.serperKey)ss.value=S.serperKey;
  const sgh=document.getElementById('s-ghtoken');if(sgh&&S.ghToken)sgh.value=S.ghToken;
  const sgr=document.getElementById('s-ghrepo');if(sgr&&S.ghUser&&S.ghRepo)sgr.value=S.ghUser+'/'+S.ghRepo;
  const sgb=document.getElementById('s-ghbranch');if(sgb)sgb.value=S.ghBranch;
  const smp=document.getElementById('s-model-pref');if(smp)smp.value=S.modelPref;
  const sam=document.getElementById('s-automem');if(sam)sam.checked=S.autoMemory;
  const svc=document.getElementById('s-vcont');if(svc)svc.checked=S.voiceCont;
  const svr=document.getElementById('s-vread');if(svr)svr.checked=S.voiceRead;
  const sr=document.getElementById('s-rate');if(sr)sr.value=S.voiceRate;
  const sp=document.getElementById('s-pitch');if(sp)sp.value=S.voicePitch;
  const srv=document.getElementById('s-rate-val');if(srv)srv.textContent=S.voiceRate.toFixed(1)+'×';
  const spv=document.getElementById('s-pitch-val');if(spv)spv.textContent=S.voicePitch.toFixed(1);
  // Populate TTS voices
  const stv=document.getElementById('s-tts-voice');
  if(stv){
    const voices=S.synth.getVoices();
    const frV=voices.filter(v=>v.lang.startsWith('fr'));
    stv.innerHTML=frV.length?frV.map((v,i)=>`<option value="${i}">${v.name} (${v.lang})</option>`).join(''):'<option>(Voix système)</option>';
  }
  // Render memory list
  renderSettingsMemList();
  updateApiSt();
}
function closeSettings(){document.getElementById('settings-modal').classList.remove('open');}
function showStab(name){
  document.querySelectorAll('.stab').forEach(b=>b.classList.remove('act'));
  document.querySelectorAll('.stab-pane').forEach(p=>p.classList.remove('act'));
  const tb=document.getElementById('stab-'+name);if(tb)tb.classList.add('act');
  const p=document.getElementById('stab-content-'+name);if(p)p.classList.add('act');
}
function saveSettings(){
  const sg=document.getElementById('s-groq')?.value.trim();
  const ss=document.getElementById('s-serper')?.value.trim();
  const sgh=document.getElementById('s-ghtoken')?.value.trim();
  const sgr=document.getElementById('s-ghrepo')?.value.trim();
  const sgb=document.getElementById('s-ghbranch')?.value.trim()||'main';
  if(sg){S.groqKey=sg;localStorage.setItem('ixa_groq_key',sg);}
  if(ss){S.serperKey=ss;localStorage.setItem('ixa_serper_key',ss);}
  if(sgh){S.ghToken=sgh;localStorage.setItem('ixa_gh_token',sgh);}
  if(sgr&&sgr.includes('/')){const p=sgr.split('/');S.ghUser=p[0];S.ghRepo=p[1];localStorage.setItem('ixa_gh_repo',sgr);}
  S.ghBranch=sgb;localStorage.setItem('ixa_gh_branch',sgb);
  // Model pref
  const smp=document.getElementById('s-model-pref')?.value;if(smp){S.modelPref=smp;localStorage.setItem('ixa_model_pref',smp);}
  // Voice settings
  const sr=parseFloat(document.getElementById('s-rate')?.value||'1');
  const sp=parseFloat(document.getElementById('s-pitch')?.value||'1');
  S.voiceRate=sr;S.voicePitch=sp;
  const svc=document.getElementById('s-vcont');if(svc)S.voiceCont=svc.checked;
  const svr=document.getElementById('s-vread');if(svr)S.voiceRead=svr.checked;
  // Auto memory
  const sam=document.getElementById('s-automem');if(sam){S.autoMemory=sam.checked;localStorage.setItem('ixa_automem',sam.checked);}
  // Account
  if(S.user){
    const dn=document.getElementById('s-dname')?.value.trim();if(dn)S.user.display_name=dn;
    const av=document.getElementById('s-avatar')?.value.trim();if(av)S.user.avatar=av;
    const pw=document.getElementById('s-newpw')?.value.trim();if(pw)S.user.password=pw;
    const aidx=S.allUsers?.users.findIndex(u=>u.id===S.user.id);
    if(aidx>=0)S.allUsers.users[aidx]={...S.allUsers.users[aidx],...S.user};
  }
  // Sync interval
  const si=parseInt(document.getElementById('s-sync-interval')?.value||'2');
  localStorage.setItem('ixa_sync_int',si);startSyncInterval(si);
  // Font size
  const fs=document.getElementById('s-fontsize')?.value;
  if(fs)document.documentElement.style.fontSize=parseInt(fs)+'px';
  saveLocal();updateUserUI();updateApiSt();closeSettings();
  toast('✅ Paramètres sauvegardés !','ok');
  setTimeout(()=>pushUsers(),500);
}

